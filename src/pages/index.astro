---
import { SEO } from "astro-seo";
import "../styles/global.css";

import About from "@components/About.astro";
import Contact from "@components/Contact.astro";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Portfolio from "@components/Portfolio.astro";
import Testimonials from "@components/Testimonials.astro";
import Type from "@components/Type.astro";

const title = `Avaab Razzaq - AI-Driven Growth Engineer`;
const description = `I build intelligent AI systems and the marketing engines that scale them.`;
---

<html lang="en" class="scroll-smooth" style="background: radial-gradient(circle at 12% 15%, var(--bg-mesh-a), transparent 40%), radial-gradient(circle at 86% 28%, var(--bg-mesh-b), transparent 42%), var(--bg-canvas); background-attachment: fixed;">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=5.0"
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <SEO {title} {description} />
    <meta name="theme-color" content="#000000" />
  </head>
  <body class="site-shell select-none">
    <script is:inline>
      // Initialize theme immediately to prevent flash
      const storedTheme = localStorage?.getItem?.("theme");
      if (storedTheme === "dark" || (!storedTheme && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
        document.documentElement.classList.add("dark");
      }
    </script>
    <Header background="bg-[color-mix(in_srgb,var(--surface-elevated)_92%,transparent)]" />
    <section
      id="hero"
      class="relative min-h-screen grid items-center justify-center pt-24 pb-12 px-4"
    >
      <div class="max-w-screen-lg mx-auto text-center xl:max-w-screen-xl">
        <p class="text-[var(--accent-strong)] font-semibold mb-4 text-lg">AI-Driven Growth Engineer</p>
        <h1 class="font-bold text-6xl md:text-7xl mb-4 text-[var(--text-strong)]">Avaab Razzaq</h1>
        <h3 class="text-2xl md:text-3xl font-semibold text-[var(--text-muted)] mb-8">
          I'm a <Type />
        </h3>
        <p class="text-base md:text-lg text-[var(--text-muted)] max-w-2xl mx-auto mb-8">
          I combine agent design, full-stack product engineering, and conversion-focused marketing to help teams launch faster and grow smarter.
        </p>
        <div class="flex gap-4 justify-center flex-wrap">
          <a 
            href="https://cal.com/ar10dev"
            class="px-8 py-3 bg-[var(--accent-strong)] text-[var(--accent-contrast)] font-semibold rounded-lg hover:opacity-90 transition-all"
          >
            Book a Strategy Call
          </a>
          <a 
            href="#work"
            class="px-8 py-3 border-2 border-[var(--accent-strong)] text-[var(--accent-strong)] font-semibold rounded-lg hover:bg-[var(--accent-strong)] hover:text-[var(--accent-contrast)] transition-all"
          >
            Explore Case Studies
          </a>
        </div>
      </div>
    </section>
    <About />
    <Portfolio />
    <Testimonials />
    <Contact />
    <Footer />
    <script>
      import "../scripts/homepage";
      import "../scripts/scroll-reveal";
    </script>
  </body>
</html>
