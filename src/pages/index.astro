---
import { getCollection, getEntry } from "astro:content";
import {
  BUTTON_CLASSES,
  CONTAINER_CLASSES,
  FORM_CLASSES,
  TYPING_CLASSES,
  TYPOGRAPHY_CLASSES,
} from "@lib/constants";
import "../styles/global.css";

import SocialLinks from "@components/SocialLinks.astro";
import FormField from "@components/ui/FormField.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import Typer from "@solid-components/Typer";

const kickerClass = TYPOGRAPHY_CLASSES.kicker;
const titleClass = TYPOGRAPHY_CLASSES.title;
const copyClass = TYPOGRAPHY_CLASSES.body;
const primaryButtonClass = `${BUTTON_CLASSES.base} ${BUTTON_CLASSES.primary}`;
const secondaryButtonClass = `${BUTTON_CLASSES.base} ${BUTTON_CLASSES.secondary}`;
const leadInputClass = FORM_CLASSES.input;

const homepageEntry = await getEntry("site", "homepage");
if (!homepageEntry) {
  throw new Error("Missing content entry: site/homepage.json");
}

const homepage = homepageEntry.data;

const portfolioItems = (await getCollection("portfolio"))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const siteUrl = "https://avaabrazzaq.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL("/og-ai-growth-engineer.svg", siteUrl).toString();
const linkedInUrl = "https://www.linkedin.com/in/ar10dev";
const twitterUrl = "https://twitter.com/itsmeAvaab";
const seoTitle = "AI Growth Engineer Services in Miami | Avaab Razzaq";
const seoDescription =
  "Hire Avaab Razzaq for AI automation, full-stack web development, and technical SEO in Miami, FL. Book a discovery call to accelerate growth.";

const rolePhrases = [
  "web apps that convert.",
  "AI automation systems.",
  "technical SEO strategies.",
  "growth engineering solutions.",
];

const socialLinks = [
  {
    kind: "linkedin" as const,
    href: linkedInUrl,
    label: "LinkedIn",
    trackId: "open_linkedin_hero",
  },
  {
    kind: "github" as const,
    href: homepage.githubUrl,
    label: "GitHub",
    trackId: "open_github_hero",
  },
];

const heroFeatures = [
  {
    title: "AI Automation & MCP",
    body: "Custom AI automation systems, n8n workflows, and Model Context Protocol integrations that connect your AI to real-world business actions.",
    href: "/services/ai-automation/",
  },
  {
    title: "Full Stack Development",
    body: "Production-ready web and mobile applications built with Astro, React, SolidJS, and modern AI-native architectures.",
    href: "/services/fullstack-development/",
  },
  {
    title: "Technical SEO & GEO",
    body: "Technical SEO strategies combined with Generative Engine Optimization to rank on Google and get cited by AI systems.",
    href: "/services/technical-seo/",
  },
];

const serviceItems = [
  {
    title: "AI Automation Development",
    body: "Stop doing manual work. I build n8n pipelines, Claude API integrations, and custom agentic workflows that automate repetitive tasks so your business runs while you sleep.",
    href: "/services/ai-automation/",
  },
  {
    title: "MCP Integration & Agentic AI",
    body: "Connect your AI to the real world. I build Model Context Protocol servers so your AI agents can access databases, call APIs, and take real actions in your business systems.",
    href: "/services/mcp-integration/",
  },
  {
    title: "Technical SEO & GEO",
    body: "Rank on Google and get found by AI. I combine technical SEO with Generative Engine Optimization so you're visible in both traditional search and AI-powered answers.",
    href: "/services/technical-seo/",
  },
  {
    title: "Full Stack Development",
    body: "Ship fast, scale smart. I build production-ready web and mobile applications using Astro, React, SolidJS, and modern AI-native architectures.",
    href: "/services/fullstack-development/",
  },
];

const emergingServiceSlugs = [
  "ai-agent-development",
  "prompt-engineering",
  "social-media-growth",
];

const emergingServiceItems = (await getCollection("services"))
  .filter((entry) => emergingServiceSlugs.includes(entry.data.slug))
  .map((entry) => ({
    title: entry.data.title,
    body: entry.data.heroSubtitle,
    href: `/services/${entry.data.slug}/`,
  }));

const homepageServiceItems = [...serviceItems, ...emergingServiceItems];

// Enhanced structured data with local business info for SEO
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      name: "Avaab Razzaq",
      alternateName: "AR10Dev",
      jobTitle: "AI Growth Engineer",
      description:
        "AI Growth Engineer helping businesses build web apps, implement AI automation, and scale technical SEO and GEO performance.",
      url: siteUrl,
      image: ogImage,
      sameAs: [homepage.githubUrl, linkedInUrl, twitterUrl],
      address: {
        "@type": "PostalAddress",
        addressLocality: "Miami",
        addressRegion: "FL",
        addressCountry: "US",
      },
      knowsAbout: [
        "AI Automation",
        "Model Context Protocol",
        "Agentic AI Systems",
        "Technical SEO",
        "Generative Engine Optimization",
        "Full Stack Web Development",
        "Prompt Engineering",
        "LLM Integration",
      ],
      hasOccupation: {
        "@type": "Occupation",
        name: "AI Growth Engineer",
      },
      hasCredential: {
        "@type": "EducationalOccupationalCredential",
        credentialCategory: "Professional Expertise",
        name: "AI Growth Engineering Practitioner",
      },
      worksFor: {
        "@type": "Organization",
        name: "Independent Consultant",
      },
      offers: [
        {
          "@type": "Offer",
          name: "AI Integrations and Automation",
          description:
            "Custom LLM integrations and workflow automation services",
          url: `${siteUrl}/services/ai-automation/`,
        },
        {
          "@type": "Offer",
          name: "Full-Stack Web Development",
          description:
            "Modern web applications with Astro, SolidJS, and cloud infrastructure",
          url: `${siteUrl}/services/web-development/`,
        },
        {
          "@type": "Offer",
          name: "SEO and Growth Strategy",
          description: "Technical SEO and programmatic marketing systems",
          url: `${siteUrl}/services/seo-growth/`,
        },
      ],
    },
    {
      "@type": "ProfessionalService",
      "@id": `${siteUrl}/#business`,
      name: "Avaab Razzaq - AI Growth Engineer",
      description: homepage.metaDescription,
      url: siteUrl,
      email: homepage.contactEmail,
      provider: {
        "@id": `${siteUrl}/#person`,
      },
      address: {
        "@type": "PostalAddress",
        addressLocality: "Miami",
        addressRegion: "FL",
        addressCountry: "US",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 25.7617,
        longitude: -80.1918,
      },
      areaServed: [
        { "@type": "City", name: "Miami" },
        { "@type": "State", name: "Florida" },
        { "@type": "Country", name: "United States" },
      ],
      priceRange: "$$",
      openingHoursSpecification: {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        opens: "09:00",
        closes: "18:00",
      },
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      name: "Avaab Razzaq - AI Growth Engineer",
      url: siteUrl,
      logo: {
        "@type": "ImageObject",
        "@id": `${siteUrl}/#logo`,
        url: `${siteUrl}/pwa-512x512.png`,
        contentUrl: `${siteUrl}/pwa-512x512.png`,
        width: 512,
        height: 512,
        caption: "Avaab Razzaq - AI Growth Engineer",
      },
      sameAs: [homepage.githubUrl, linkedInUrl, twitterUrl],
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      name: homepage.brandTitle,
      url: siteUrl,
      description: homepage.metaDescription,
      inLanguage: "en-US",
      publisher: {
        "@id": `${siteUrl}/#organization`,
      },
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: `${siteUrl}/blog/?q={search_term_string}`,
        },
        "query-input": "required name=search_term_string",
      },
    },
    {
      "@type": "WebPage",
      "@id": canonicalUrl,
      url: canonicalUrl,
      name: homepage.brandTitle,
      description: homepage.metaDescription,
      isPartOf: {
        "@id": `${siteUrl}/#website`,
      },
      mainEntity: {
        "@id": `${siteUrl}/#person`,
      },
      speakable: {
        "@type": "SpeakableSpecification",
        cssSelector: ["h1", ".hero-subheadline", ".service-intro"],
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: `${siteUrl}/`,
        },
      ],
    },
  ],
};
---

<BaseLayout 
  title={seoTitle} 
  description={seoDescription}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  structuredData={structuredData}
>

    <main id="main-content" class="scroll-smooth" tabindex="-1">
      {/* Hero Section */}
      <section id="home" class="min-h-[90vh] flex items-center py-20" aria-labelledby="hero-title">
        <div class="mx-auto w-full max-w-screen-xl px-6">
          <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
            <div>
              <p class={kickerClass}>{homepage.kicker}</p>
              <h1 id="hero-title" class={TYPOGRAPHY_CLASSES.heroTitle}>
                Avaab Razzaq — AI Growth Engineer
              </h1>
              <p class={`${TYPOGRAPHY_CLASSES.subheading} hero-subheadline service-intro`}>
                <span class={TYPING_CLASSES.fallback}>I build web apps, AI automation, and technical SEO systems.</span>
                <span class={TYPING_CLASSES.live} aria-hidden="true">
                  I build <Typer text={rolePhrases} cursor cursorClassName={TYPING_CLASSES.cursor} loop typingSpeed={90} backspaceSpeed={80} typingPause={1300} client:load />
                </span>
                <span class="sr-only">
                  I build web apps, AI automation systems, and technical SEO strategies. I am an AI Growth Engineer serving clients across the United States.
                </span>
              </p>
              <p class={`mt-6 w-full text-pretty ${copyClass}`}>
                {homepage.heroLead}
              </p>
              <p class="mt-3 text-sm text-[var(--text-muted)]">
                Based in <strong class="text-[var(--text-strong)]">Miami, Florida</strong> • Serving clients across the <strong class="text-[var(--text-strong)]">United States</strong>
              </p>
              <div class="mt-10 flex flex-wrap gap-4">
                <a href="/contact/" class={primaryButtonClass} data-track="cta_hero_primary">Book a Discovery Call</a>
                <a href="/portfolio/" class={secondaryButtonClass} data-track="cta_hero_secondary">See My Work</a>
              </div>
              <SocialLinks links={socialLinks} variant="icon" className="mt-6 gap-3" />
            </div>
            
            <div class="grid gap-4 md:grid-cols-1">
              <h2 class="sr-only">Featured Growth Engineering Services</h2>
              {heroFeatures.map((feature) => (
                <a href={feature.href} class="group block rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)] transition-all hover:-translate-y-0.5 hover:shadow-lg hover:border-[var(--accent-strong)]/30">
                  <h3 class="font-bold text-[var(--text-strong)] group-hover:text-[var(--accent-strong)] transition-colors">{feature.title}</h3>
                  <p class="mt-2 text-sm text-[var(--text-muted)]">{feature.body}</p>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      {/* Services Section */}
      <section id="services" class="py-20 bg-[var(--surface-elevated)]" aria-labelledby="services-title">
        <div class={CONTAINER_CLASSES.horizontal}>
          <div class="text-center mb-12">
            <p class={kickerClass}>AI Growth Engineer Services</p>
            <h2 id="services-title" class={`mt-3 ${titleClass}`}>Web Apps, AI Automation & Technical SEO</h2>
            <p class={`mt-4 max-w-3xl mx-auto ${copyClass}`}>
              I help businesses build scalable web apps, implement AI automation to save time, and drive aggressive growth through technical SEO strategies. My solutions are designed for measurable business impact.
            </p>
          </div>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
            {homepageServiceItems.map((service) => (
              <a href={service.href} class="group flex flex-col rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)] transition-all hover:-translate-y-1 hover:shadow-xl">
                <h3 class="text-lg font-bold text-[var(--text-strong)] group-hover:text-[var(--accent-strong)] transition-colors">{service.title}</h3>
                <p class="mt-3 text-sm text-[var(--text-muted)] flex-grow">{service.body}</p>
                <span class="mt-4 text-sm font-semibold text-[var(--accent-strong)]">Get started →</span>
              </a>
            ))}
          </div>
          <div class="mt-10 text-center">
            <a href="/services/" class={secondaryButtonClass}>View All Services</a>
          </div>
        </div>
      </section>

      {/* Portfolio Section */}
      <section id="work" class="py-20" aria-labelledby="work-title">
        <div class={CONTAINER_CLASSES.horizontal}>
          <div class="flex flex-wrap items-end justify-between gap-4 mb-10">
            <div>
              <p class={kickerClass}>Growth Engineering Portfolio</p>
              <h2 id="work-title" class={`mt-3 ${titleClass}`}>Web Apps & AI Automation Projects</h2>
              <p class={`mt-4 max-w-2xl ${copyClass}`}>
                Proof-of-concept builds demonstrating AI automation, web app development, and technical SEO solutions. Each project showcases what I can deliver for your business as an AI growth engineer.
              </p>
            </div>
            <a href="/portfolio/" class={secondaryButtonClass}>View All Projects</a>
          </div>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {portfolioItems.map((item) => (
              <article class="group flex flex-col rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)] transition-all hover:-translate-y-1 hover:shadow-xl" itemscope itemtype="https://schema.org/SoftwareApplication">
                <p class="text-xs font-bold uppercase tracking-widest text-[var(--accent-strong)]" itemprop="applicationCategory">{item.data.category}</p>
                <h3 class="mt-2 text-lg font-bold text-[var(--text-strong)] group-hover:text-[var(--accent-strong)] transition-colors" itemprop="name">
                  <a href={`/portfolio/${item.id}/`}>{item.data.title}</a>
                </h3>
                <p class="mt-3 text-sm text-[var(--text-muted)] flex-grow">{item.data.summary}</p>
                <div class="mt-4 flex flex-wrap gap-1.5">
                  {item.data.stack.slice(0, 3).map((tech) => (
                    <span class="rounded bg-[var(--surface-elevated)] px-2 py-0.5 text-xs text-[var(--text-muted)]">{tech}</span>
                  ))}
                </div>
                <a href={`/portfolio/${item.id}/`} class="mt-4 text-sm font-semibold text-[var(--accent-strong)] hover:underline">
                  View details →
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>

      {/* Contact CTA Section */}
      <section id="contact" class="py-20 bg-[var(--surface-elevated)]" aria-labelledby="contact-title">
        <div class={CONTAINER_CLASSES.horizontal}>
          <div class="grid items-center gap-12 lg:grid-cols-2">
            <div>
              <p class={kickerClass}>Contact Avaab Razzaq</p>
              <h2 id="contact-title" class={`mt-3 ${titleClass}`}>Let's Build Something Together</h2>
              <p class={`mt-4 ${copyClass}`}>
                Share your product and growth goals, and I will propose a focused roadmap for AI automation, web app development, and technical SEO optimization. Whether you need help building web apps, implementing AI growth automation, or improving your technical SEO, I'm here to help your business succeed.
              </p>
              <ul class="mt-6 space-y-2 text-[var(--text-muted)]" aria-label="Engagement trust signals">
                <li class="flex items-center gap-2">
                  <svg class="h-5 w-5 text-[var(--accent-strong)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  {homepage.responseTime}
                </li>
                <li class="flex items-center gap-2">
                  <svg class="h-5 w-5 text-[var(--accent-strong)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  Timezone: {homepage.timezone}
                </li>
                <li class="flex items-center gap-2">
                  <svg class="h-5 w-5 text-[var(--accent-strong)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  Location: {homepage.location}
                </li>
                <li class="flex items-center gap-2">
                  <svg class="h-5 w-5 text-[var(--accent-strong)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  {homepage.availability}
                </li>
              </ul>
              <div class="mt-8 flex flex-wrap gap-4">
                <a class={primaryButtonClass} href="/contact/" data-track="cta_contact_page">Get in Touch</a>
                <a class={secondaryButtonClass} href={homepage.bookingUrl} target="_blank" rel="noopener noreferrer" data-track="cta_booking_link">
                  Book a Calendar Slot
                </a>
              </div>
            </div>
            
            <div class="rounded-2xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-8 shadow-[var(--card-shadow)]">
              <p class={`${kickerClass} text-xs`}>Quick Inquiry</p>
              <form class="mt-6" method="POST" name="homepage-lead" action="/contact/">
                <input type="hidden" name="form-name" value="homepage-lead" />
                <div class="grid gap-4 md:grid-cols-2">
                  <FormField label="Name">
                    <input class={leadInputClass} type="text" name="name" required aria-required="true" placeholder="John Doe" />
                  </FormField>
                  <FormField label="Email">
                    <input class={leadInputClass} type="email" name="email" required aria-required="true" placeholder="john@example.com" />
                  </FormField>
                </div>
                <FormField label="What do you need help with?" className="mt-4">
                  <select class={leadInputClass} name="projectType" required aria-required="true">
                    <option value="">Select one...</option>
                    <option value="ai-automation">AI & Automation</option>
                    <option value="web-development">Web Development</option>
                    <option value="seo-growth">SEO & Growth</option>
                    <option value="other">Other</option>
                  </select>
                </FormField>
                <FormField label="Tell me about your project" className="mt-4">
                  <textarea class={leadInputClass} name="message" rows={3} required aria-required="true" placeholder="Brief description of your goals..."></textarea>
                </FormField>
                <button class={`${primaryButtonClass} mt-6 w-full`} type="submit">Send Inquiry</button>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>
</BaseLayout>
