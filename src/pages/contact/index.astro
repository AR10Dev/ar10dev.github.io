---
import { getEntry } from "astro:content";
import Breadcrumb from "@components/Breadcrumb.astro";
import FormField from "@components/ui/FormField.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
  BUTTON_CLASSES,
  CONTAINER_CLASSES,
  FORM_CLASSES,
  TYPOGRAPHY_CLASSES,
} from "@lib/constants";

const homepageEntry = await getEntry("site", "homepage");
if (!homepageEntry) {
  throw new Error("Missing content entry: site/homepage.json");
}

const homepage = homepageEntry.data;

const title = "Contact Avaab Razzaq | AI Growth Engineer in Miami";
const description =
  "Contact Avaab Razzaq for AI automation, web development, and technical SEO services from Miami, FL. Book a discovery call and get a fast project response.";

const siteUrl = "https://avaabrazzaq.com";
const canonicalUrl = new URL("/contact/", siteUrl).toString();

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: "Avaab Razzaq - AI Growth Engineer",
      description:
        "AI Growth Engineer specializing in web apps, AI automation, and technical SEO",
      publisher: { "@id": `${siteUrl}/#person` },
    },
    {
      "@type": "ContactPage",
      "@id": canonicalUrl,
      url: canonicalUrl,
      name: "Contact Avaab Razzaq",
      description: description,
      isPartOf: { "@id": `${siteUrl}/#website` },
      mainEntity: { "@id": `${siteUrl}/#person` },
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      name: "Avaab Razzaq",
      email: homepage.contactEmail,
      url: siteUrl,
      jobTitle: "AI Growth Engineer",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Miami",
        addressRegion: "FL",
        addressCountry: "US",
      },
      areaServed: [
        { "@type": "Country", name: "United States" },
        {
          "@type": "City",
          name: "Miami",
          containedInPlace: {
            "@type": "State",
            name: "Florida",
          },
        },
      ],
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "customer service",
        email: homepage.contactEmail,
        areaServed: "US",
        availableLanguage: "English",
      },
      sameAs: [
        "https://github.com/AR10Dev",
        "https://linkedin.com/in/avaabrazzaq",
        "https://twitter.com/itsmeAvaab",
      ],
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: `${siteUrl}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Contact",
        },
      ],
    },
  ],
};

const contactMethods = [
  {
    title: "Email",
    description: "Send me a message directly",
    value: homepage.contactEmail,
    href: `mailto:${homepage.contactEmail}`,
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  },
  {
    title: "Book a Call",
    description: "Schedule a discovery call",
    value: "Cal.com",
    href: homepage.bookingUrl,
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  },
  {
    title: "LinkedIn",
    description: "Connect professionally",
    value: "linkedin.com/in/ar10dev",
    href: "https://www.linkedin.com/in/ar10dev",
    icon: `<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>`,
  },
];

const leadInputClass = FORM_CLASSES.input;
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl} ogImage="https://avaabrazzaq.com/og-contact.png" structuredData={structuredData}>
  <div class="min-h-screen py-12">
    <div class={CONTAINER_CLASSES.section}>
      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Contact" }]} class="mb-8" />
      
      <header class="mb-16 text-center">
        <p class={TYPOGRAPHY_CLASSES.kicker}>Contact Avaab Razzaq</p>
        <h1 class={`mt-3 ${TYPOGRAPHY_CLASSES.heroTitle}`}>Hire an AI Growth Engineer in Miami, Florida</h1>
        <p class={`mt-6 mx-auto max-w-3xl ${TYPOGRAPHY_CLASSES.body}`}>
          Whether you need AI automation systems, high-performance web apps, or technical SEO strategies, 
          I'm here to help your business grow. As an AI growth engineer based in Miami, Florida, I work with clients across the United States to deliver measurable results through web apps, AI growth automation, and SEO growth solutions.
        </p>
      </header>

      <div class="grid gap-12 lg:grid-cols-5">
        {/* Contact Methods */}
        <div class="lg:col-span-2">
          <h2 class={TYPOGRAPHY_CLASSES.sectionTitle}>Contact Avaab Razzaq</h2>
          <p class={`mt-4 ${TYPOGRAPHY_CLASSES.body}`}>
            Choose the best way to reach me for web apps, AI automation, or technical SEO projects. I typically respond within 24 hours.
          </p>

          <div class="mt-8 space-y-4">
            {contactMethods.map((method) => (
              <a 
                href={method.href}
                target={method.href.startsWith("mailto") ? undefined : "_blank"}
                rel={method.href.startsWith("mailto") ? undefined : "noopener noreferrer"}
                class="flex items-start gap-4 rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-5 shadow-[var(--card-shadow)] transition-all hover:-translate-y-0.5 hover:border-[var(--accent-strong)]/30 hover:shadow-lg"
              >
                <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]" set:html={method.icon} />
                <div>
                  <h3 class="font-bold text-[var(--text-strong)]">{method.title}</h3>
                  <p class="text-sm text-[var(--text-muted)]">{method.description}</p>
                  <p class="mt-1 text-sm font-medium text-[var(--accent-strong)]">{method.value}</p>
                </div>
              </a>
            ))}
          </div>

          <div class="mt-10 rounded-xl border border-[var(--border-strong)] bg-[var(--surface-elevated)] p-6">
            <h3 class="font-bold text-[var(--text-strong)]">Quick Info</h3>
            <ul class="mt-4 space-y-2 text-sm text-[var(--text-muted)]">
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4 flex-shrink-0 text-[var(--accent-strong)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <span><strong>Location:</strong> {homepage.location}</span>
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4 flex-shrink-0 text-[var(--accent-strong)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
                <span><strong>Timezone:</strong> {homepage.timezone}</span>
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4 flex-shrink-0 text-[var(--accent-strong)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <span><strong>Response:</strong> {homepage.responseTime}</span>
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4 flex-shrink-0 text-[var(--accent-strong)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                <span>{homepage.availability}</span>
              </li>
            </ul>
          </div>
        </div>

        {/* Contact Form */}
        <div class="lg:col-span-3">
          <div class="rounded-2xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-8 shadow-[var(--card-shadow)]">
            <h2 class={TYPOGRAPHY_CLASSES.sectionTitle}>Send a Message</h2>
            <p class={`mt-2 text-sm text-[var(--text-muted)]`}>
              Fill out the form below and I'll get back to you as soon as possible.
            </p>

            <form class="mt-8" method="POST" name="contact-form">
              <input type="hidden" name="form-name" value="contact-form" />
              
              <div class="grid gap-5 md:grid-cols-2">
                <FormField label="Full Name">
                  <input 
                    class={leadInputClass} 
                    type="text" 
                    name="name" 
                    placeholder="John Doe"
                    required 
                    aria-required="true" 
                  />
                </FormField>
                <FormField label="Email Address">
                  <input 
                    class={leadInputClass} 
                    type="email" 
                    name="email" 
                    placeholder="john@example.com"
                    required 
                    aria-required="true" 
                  />
                </FormField>
              </div>

              <div class="mt-5 grid gap-5 md:grid-cols-2">
                <FormField label="Company (Optional)">
                  <input 
                    class={leadInputClass} 
                    type="text" 
                    name="company" 
                    placeholder="Acme Inc."
                  />
                </FormField>
                <FormField label="What do you need help with?">
                  <select class={leadInputClass} name="projectType" required aria-required="true">
                    <option value="">Select one...</option>
                    <option value="ai-automation">AI & Automation</option>
                    <option value="full-stack-web-development">Web Development</option>
                    <option value="seo-growth">SEO & Growth</option>
                    <option value="consulting">Consulting / Advisory</option>
                    <option value="other">Other</option>
                  </select>
                </FormField>
              </div>

              <FormField label="Budget Range (Optional)" className="mt-5">
                <select class={leadInputClass} name="budget">
                  <option value="">Prefer not to say</option>
                  <option value="5k-10k">$5,000 - $10,000</option>
                  <option value="10k-25k">$10,000 - $25,000</option>
                  <option value="25k-50k">$25,000 - $50,000</option>
                  <option value="50k+">$50,000+</option>
                </select>
              </FormField>

              <FormField label="Project Details" className="mt-5">
                <textarea 
                  class={leadInputClass} 
                  name="message" 
                  rows={5} 
                  placeholder="Tell me about your project, goals, and timeline..."
                  required 
                  aria-required="true"
                ></textarea>
              </FormField>

              <button 
                class={`${BUTTON_CLASSES.base} ${BUTTON_CLASSES.primary} mt-6 w-full`} 
                type="submit"
              >
                Send Message
              </button>
            </form>
          </div>
        </div>
      </div>

      {/* Service Areas */}
      <section class="mt-20 text-center">
        <h2 class={TYPOGRAPHY_CLASSES.sectionTitle}>AI Growth Engineer Service Areas</h2>
        <p class={`mt-4 mx-auto max-w-2xl ${TYPOGRAPHY_CLASSES.body}`}>
          As an AI growth engineer based in Miami, Florida, I work with clients throughout the United States and internationally. 
          Remote collaboration is my specialty—I've successfully delivered web apps, AI automation systems, and technical SEO solutions for clients across multiple time zones. Whether you need a growth engineer in Miami, Florida or anywhere in the US, I can help your business succeed.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          {["Miami", "Florida", "New York", "Los Angeles", "Chicago", "Houston", "Austin", "San Francisco", "Seattle", "Denver"].map((city) => (
            <span class="rounded-full border border-[var(--border-strong)] bg-[var(--surface-panel)] px-4 py-2 text-sm text-[var(--text-strong)]">
              {city}
            </span>
          ))}
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
