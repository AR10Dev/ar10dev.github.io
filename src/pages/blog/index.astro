---
import { getCollection } from "astro:content";
import Breadcrumb from "@components/Breadcrumb.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { CONTAINER_CLASSES, TYPOGRAPHY_CLASSES } from "@lib/constants";

const title = "Blog | Avaab Razzaq - AI Growth Engineer in Miami, Florida";
const description =
  "Insights on AI automation, technical SEO, web apps development, and growth engineering strategies by Avaab Razzaq, AI Growth Engineer in Miami, Florida.";
const siteUrl = "https://avaabrazzaq.com";
const canonicalUrl = new URL("/blog/", siteUrl).toString();
const ogImage = new URL("/og-ai-growth-engineer.svg", siteUrl).toString();

// Get all published blog posts, sorted by publish date (newest first)
const allPosts = await getCollection("blog", ({ data }) => {
  return data.draft !== true;
});

const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

// Format date helper
function formatDate(date: Date): string {
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
}
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl} ogImage={ogImage}>
  <div class="min-h-screen py-12">
    <div class={CONTAINER_CLASSES.horizontal}>
      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Blog" }]} class="mb-8" />
      
      <!-- Header -->
      <header class="mb-16 text-center">
        <p class={TYPOGRAPHY_CLASSES.kicker}>Avaab Razzaq - AI Growth Engineer</p>
        <h1 class={TYPOGRAPHY_CLASSES.heroTitle}>
          Web Apps, AI Automation & Technical SEO Blog
        </h1>
        <p class={`${TYPOGRAPHY_CLASSES.subheading} mt-4 max-w-2xl mx-auto`}>
          Insights on AI automation, technical SEO strategies, web apps development, and growth engineering from Avaab Razzaq, an AI growth engineer based in Miami, Florida. Learn how to build products that scale and drive measurable business growth.
        </p>
      </header>

      <!-- Categories Filter (Optional for future) -->
      <!-- <div class="mb-12 flex flex-wrap gap-3 justify-center">
        {allCategories.map(category => (
          <button class="px-4 py-2 rounded-full bg-[var(--surface-panel)] text-[var(--text-base)] border border-[var(--border-base)] hover:border-[var(--accent-strong)] transition-colors">
            {category}
          </button>
        ))}
      </div> -->

      <!-- Blog Posts Grid -->
      {sortedPosts.length === 0 ? (
        <div class="text-center py-20">
          <p class={TYPOGRAPHY_CLASSES.body}>
            No blog posts yet. Check back soon for insights on AI, growth engineering, and more!
          </p>
        </div>
      ) : (
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {sortedPosts.map((post) => (
            <article class="group relative flex flex-col rounded-2xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-8 shadow-[var(--card-shadow)] transition-all hover:-translate-y-1 hover:shadow-xl">
                
                {/* Post Image */}
                {post.data.image && (
                  <div class="mb-6 overflow-hidden rounded-lg aspect-video bg-[var(--surface-strong)]">
                    <img 
                      src={post.data.image.src} 
                      alt={post.data.image.alt}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                )}

                {/* Category Badge */}
                <div class="mb-3">
                  <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full bg-[var(--accent-alpha)] text-[var(--accent-strong)] border border-[var(--accent-strong)]">
                    {post.data.category}
                  </span>
                </div>

                {/* Title */}
                <h2 class={`${TYPOGRAPHY_CLASSES.cardTitleBold} mb-3`}>
                  <a href={`/blog/${post.id}/`} class="after:absolute after:inset-0 hover:text-[var(--accent-strong)] transition-colors">
                    {post.data.title}
                  </a>
                </h2>

                {/* Description */}
                <p class={`${TYPOGRAPHY_CLASSES.cardText} mb-6 flex-grow`}>
                  {post.data.description}
                </p>

                {/* Tags */}
                {post.data.tags.length > 0 && (
                  <div class="mb-6 flex flex-wrap gap-2">
                    {post.data.tags.slice(0, 3).map(tag => (
                      <span class="rounded-full bg-[var(--surface-elevated)] px-3 py-1 text-xs font-medium text-[var(--text-muted)]">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}

                {/* Meta Info */}
                <div class="flex items-center justify-between text-sm text-[var(--text-muted)]">
                  <time datetime={post.data.publishDate.toISOString()}>
                    {formatDate(post.data.publishDate)}
                  </time>
                  {post.data.readingTime && (
                    <span>{post.data.readingTime} min read</span>
                  )}
                </div>
              </article>
          ))}
        </div>
      )}

      <!-- Featured Posts Section (Optional for future) -->
      <!-- <section class="mt-20">
        <h2 class={`${TYPOGRAPHY_CLASSES.sectionTitle} mb-8`}>Featured Articles</h2>
      </section> -->

    </div>
  </div>
</BaseLayout>
