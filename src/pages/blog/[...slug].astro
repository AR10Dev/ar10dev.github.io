---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Breadcrumb from "@components/Breadcrumb.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
  BUTTON_CLASSES,
  CONTAINER_CLASSES,
  TYPOGRAPHY_CLASSES,
} from "@lib/constants";

export async function getStaticPaths() {
  const blogPosts = await getCollection("blog", ({ data }) => {
    return data.draft !== true;
  });
  const services = await getCollection("services");

  return blogPosts.map((post) => {
    // Find related service based on relatedService field or category mapping
    let relatedService = null;
    if (post.data.relatedService) {
      relatedService = services.find(
        (s) => s.data.slug === post.data.relatedService,
      );
    }

    // If no explicit relatedService, try to match by category
    if (!relatedService) {
      const categoryServiceMap: Record<string, string> = {
        AI: "ai-automation",
        Marketing: "seo-growth",
        Development: "web-development",
        Growth: "seo-growth",
        Analytics: "conversion-optimization",
        Tutorial: "web-development",
      };
      const mappedSlug = categoryServiceMap[post.data.category];
      if (mappedSlug) {
        relatedService = services.find((s) => s.data.slug === mappedSlug);
      }
    }

    return {
      params: { slug: post.id },
      props: { post, relatedService },
    };
  });
}

interface Props {
  post: CollectionEntry<"blog">;
  relatedService: CollectionEntry<"services"> | null;
}

const { post, relatedService } = Astro.props;
const { Content, headings } = await render(post);

const siteUrl = "https://avaabrazzaq.com";
const title = `${post.data.title} | Blog - Avaab Razzaq`;
const description = post.data.description;
const canonicalUrl = new URL(`/blog/${post.id}/`, siteUrl).toString();
const ogImage =
  post.data.image?.src ??
  new URL("/og-ai-growth-engineer.svg", siteUrl).toString();

// Format date helper
function formatDate(date: Date): string {
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
}

// Calculate reading time if not in frontmatter
const readingTime =
  post.data.readingTime ||
  (() => {
    const wordsPerMinute = 200;
    const content = post.body ?? "";
    const wordCount = content.split(/\s+/).length;
    return Math.ceil(wordCount / wordsPerMinute);
  })();

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  author: {
    "@type": "Person",
    name: post.data.author,
    url: siteUrl,
  },
  datePublished: post.data.publishDate.toISOString(),
  ...(post.data.updatedDate && {
    dateModified: post.data.updatedDate.toISOString(),
  }),
  ...(post.data.image && {
    image: {
      "@type": "ImageObject",
      url: post.data.image.src,
      caption: post.data.image.alt,
    },
  }),
  publisher: {
    "@type": "Person",
    name: "Avaab Razzaq",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
  keywords: post.data.tags.join(", "),
  articleSection: post.data.category,
};
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl} ogImage={ogImage} structuredData={structuredData}>
  <article class="min-h-screen py-12">
    <div class={CONTAINER_CLASSES.horizontal}>
      <div class="mx-auto max-w-3xl">
        <Breadcrumb items={[
          { label: "Home", href: "/" },
          { label: "Blog", href: "/blog/" },
          { label: post.data.title }
        ]} class="mb-8" />
      
      <!-- Back to Blog Link -->
      <a 
        href="/blog/" 
        class="inline-flex items-center gap-2 text-[var(--accent-strong)] hover:underline mb-8 group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back to Blog
      </a>

      <!-- Article Header -->
      <header class="mb-12">
        <!-- Category Badge -->
        <div class="mb-4">
          <span class="inline-block px-3 py-1 text-sm font-semibold rounded-full bg-[var(--accent-alpha)] text-[var(--accent-strong)] border border-[var(--accent-strong)]">
            {post.data.category}
          </span>
        </div>

        <!-- Title -->
        <h1 class={`${TYPOGRAPHY_CLASSES.heroTitle} mb-6`}>
          {post.data.title}
        </h1>

        <!-- Description -->
        <p class={`${TYPOGRAPHY_CLASSES.subheading} mb-8`}>
          {post.data.description}
        </p>

        <!-- Meta Info -->
        <div class="flex flex-wrap items-center gap-4 text-sm text-[var(--text-base)] border-t border-b border-[var(--border-base)] py-4">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            <span>{post.data.author}</span>
          </div>
          
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <time datetime={post.data.publishDate.toISOString()}>
              {formatDate(post.data.publishDate)}
            </time>
          </div>

          {post.data.updatedDate && (
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 4 23 10 17 10"></polyline>
                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
              </svg>
              <span>Updated {formatDate(post.data.updatedDate)}</span>
            </div>
          )}

          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            <span>{readingTime} min read</span>
          </div>
        </div>

        <!-- Featured Image -->
        {post.data.image && (
          <div class="mt-8 overflow-hidden rounded-lg aspect-video bg-[var(--surface-strong)]">
            <img 
              src={post.data.image.src} 
              alt={post.data.image.alt}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
        )}
      </header>

      <!-- Table of Contents (if headings exist) -->
      {headings.length > 0 && (
        <aside class="mb-12 p-6 rounded-lg bg-[var(--surface-panel)] border border-[var(--border-base)]">
          <h2 class="text-lg font-bold text-[var(--text-strong)] mb-4">Table of Contents</h2>
          <nav>
            <ul class="space-y-2">
              {headings.map((heading: { depth: number; slug: string; text: string }) => (
                <li style={`margin-left: ${(heading.depth - 1) * 1}rem`}>
                  <a 
                    href={`#${heading.slug}`}
                    class="text-[var(--text-base)] hover:text-[var(--accent-strong)] transition-colors"
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}

      <!-- Article Content -->
      <div class="prose-blog">
        <Content />
      </div>

      <!-- Tags -->
      {post.data.tags.length > 0 && (
        <div class="mt-12 pt-8 border-t border-[var(--border-base)]">
          <h3 class="text-sm font-semibold text-[var(--text-base)] mb-4">Tags:</h3>
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map(tag => (
              <span class="px-3 py-1 text-sm rounded-full bg-[var(--surface-panel)] text-[var(--text-base)] border border-[var(--border-base)]">
                #{tag}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Related Service Section -->
      {relatedService && (
        <div class="mt-12 pt-8 border-t border-[var(--border-base)]">
          <h3 class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wide mb-4">Related Service</h3>
          <a 
            href={`/services/${relatedService.data.slug}/`}
            class="block rounded-2xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)] transition-all hover:-translate-y-1 hover:shadow-xl group"
          >
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-[var(--accent-strong)] flex items-center justify-center text-white">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                  <path d="M2 17l10 5 10-5"></path>
                  <path d="M2 12l10 5 10-5"></path>
                </svg>
              </div>
              <div class="flex-1">
                <h4 class="text-lg font-bold text-[var(--text-strong)] group-hover:text-[var(--accent-strong)] transition-colors mb-2">
                  {relatedService.data.title}
                </h4>
                <p class="text-[var(--text-muted)] text-sm leading-relaxed mb-3">
                  {relatedService.data.metaDescription}
                </p>
                <span class="inline-flex items-center gap-2 text-sm font-medium text-[var(--accent-strong)]">
                  Learn more
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        </div>
      )}

      <!-- Found This Helpful CTA -->
      <div class="mt-12 p-8 rounded-2xl bg-[var(--surface-panel)] border border-[var(--border-base)] text-center">
        <h3 class={`${TYPOGRAPHY_CLASSES.sectionTitle} mb-4`}>
          Found this helpful?
        </h3>
        <p class={`${TYPOGRAPHY_CLASSES.body} mb-6 max-w-lg mx-auto`}>
          Let's work together on your next project. I specialize in AI automation, growth engineering, and full-stack development.
        </p>
        <a 
          href="/contact/" 
          class={`${BUTTON_CLASSES.base} ${BUTTON_CLASSES.primary}`}
        >
          Get in Touch
        </a>
      </div>

      </div>
    </div>
  </article>
</BaseLayout>
