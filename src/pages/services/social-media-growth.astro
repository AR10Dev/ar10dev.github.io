---
import ServiceLayout from "@layouts/ServiceLayout.astro";
import { CONTAINER_CLASSES, TYPOGRAPHY_CLASSES } from "@lib/constants";

const faqs = [
  {
    question: "Will the AI content sound generic?",
    answer:
      "Only if it's not calibrated properly. I build content pipelines trained on your existing writing, your voice, your takes — not generic brand-speak. The output gets reviewed and refined before scheduling. The AI handles speed; you maintain authenticity.",
  },
  {
    question: "Which platforms do you focus on?",
    answer:
      "Twitter/X and LinkedIn are the highest ROI for most founders and B2B businesses. I can also build systems for Instagram (Reels), YouTube Shorts, and TikTok. I'll recommend the right platforms based on your audience and goals.",
  },
  {
    question: "Do you manage accounts ongoing, or hand off the system?",
    answer:
      "Both options available. I can manage the full pipeline ongoing — strategy, content, scheduling, reporting — or build the system, document it fully, and hand it off to you or a team member. Most clients prefer a hybrid: I run it for 90 days to prove the system, then hand off.",
  },
  {
    question:
      "How is this different from hiring a generic social media manager?",
    answer:
      "A typical SMM freelancer manually creates and posts content. I build automated systems that produce at 5× the output at lower cost, with analytics dashboards you own. And because I'm an AI engineer, I integrate automation into your broader workflow — repurposing content across platforms automatically.",
  },
];
---

<ServiceLayout
  title="AI-Powered Social Media Growth Services | Avaab Razzaq"
  description="Social media growth services powered by AI automation. I build content pipelines, growth systems, and analytics dashboards that grow your audience on autopilot."
  heroHeadline="Grow Your Audience With AI-Powered Social Systems"
  heroSubheadline="I build AI-automated content pipelines, growth strategies, and analytics dashboards that grow your social presence consistently — without you manually posting every day."
  ctaText="Book a Free Discovery Call"
  ctaHref="/contact/"
  serviceName="AI-Powered Social Media Growth"
  serviceDescription="Social media growth services combining AI automation, content strategy, and analytics. Automated content pipelines and growth systems for founders and businesses."
  keywords={["social media growth services", "AI social media automation", "social media content pipeline", "automated social media growth"]}
  faqs={faqs}
>
  {/* Problem Section */}
  <section class="py-16">
    <div class={CONTAINER_CLASSES.section}>
      <div class="max-w-3xl">
        <p class={TYPOGRAPHY_CLASSES.kicker}>The Problem</p>
        <h2 class={`mt-3 ${TYPOGRAPHY_CLASSES.sectionTitle}`}>Inconsistency Is Killing Your Audience Growth</h2>
        <div class={`mt-6 space-y-4 ${TYPOGRAPHY_CLASSES.body}`}>
          <p>
            Most founders and businesses know they should be building an audience on social media but never do it consistently because it takes time they don't have.
          </p>
          <p>
            Manual posting, content ideation, scheduling, and analytics tracking across multiple platforms is a part-time job. The result: sporadic bursts of activity followed by weeks of silence — the worst possible signal to both algorithms and potential clients.
          </p>
          <p>
            With the right AI automation stack, 80% of that work can be systematized. You show up consistently without it dominating your calendar.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Solution Section */}
  <section class="bg-[var(--surface-elevated)] py-16">
    <div class={CONTAINER_CLASSES.section}>
      <div class="max-w-3xl">
        <p class={TYPOGRAPHY_CLASSES.kicker}>The Solution</p>
        <h2 class={`mt-3 ${TYPOGRAPHY_CLASSES.sectionTitle}`}>A Social Media System That Runs on Near-Autopilot</h2>
        <div class={`mt-6 space-y-4 ${TYPOGRAPHY_CLASSES.body}`}>
          <p>
            I build automation-first social systems that combine strategy, content production, scheduling, and analytics into one repeatable growth engine.
          </p>
        </div>
        <div class="mt-8 grid gap-4 md:grid-cols-2">
          <div class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)]">
            <h3 class="text-lg font-bold text-[var(--text-strong)]">AI Content Pipeline</h3>
            <p class="mt-2 text-[var(--text-muted)]">Content generation workflows calibrated to your voice — not generic AI output — with automated scheduling via n8n or Make.</p>
          </div>
          <div class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)]">
            <h3 class="text-lg font-bold text-[var(--text-strong)]">Growth Strategy</h3>
            <p class="mt-2 text-[var(--text-muted)]">Platform selection, content pillars, editorial calendar, and audience growth playbook tailored to your business goals.</p>
          </div>
          <div class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)]">
            <h3 class="text-lg font-bold text-[var(--text-strong)]">Content Repurposing</h3>
            <p class="mt-2 text-[var(--text-muted)]">Automated workflows that turn long-form content into threads, clips, carousels, and newsletters across platforms.</p>
          </div>
          <div class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)]">
            <h3 class="text-lg font-bold text-[var(--text-strong)]">Analytics Dashboard</h3>
            <p class="mt-2 text-[var(--text-muted)]">Growth tracking dashboards and monthly performance reviews with clear next-step recommendations.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* What's Included Section */}
  <section class="py-16">
    <div class={CONTAINER_CLASSES.section}>
      <div class="max-w-3xl">
        <p class={TYPOGRAPHY_CLASSES.kicker}>What's Included</p>
        <h2 class={`mt-3 ${TYPOGRAPHY_CLASSES.sectionTitle}`}>End-to-End Social Growth Delivery</h2>
        <ul class="mt-8 space-y-4">
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Platform strategy + content pillar design</h3>
              <p class="mt-1 text-[var(--text-muted)]">Define channels and themes aligned to your audience and goals.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Brand voice calibration + content guidelines</h3>
              <p class="mt-1 text-[var(--text-muted)]">Lock in messaging consistency before scaling output volume.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">AI content generation pipeline setup</h3>
              <p class="mt-1 text-[var(--text-muted)]">Build generation workflows for repeatable, on-brand content drafts.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Editorial calendar + scheduling automation (n8n / Make)</h3>
              <p class="mt-1 text-[var(--text-muted)]">Automate publishing cadence across selected channels.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Content repurposing workflows (long → short form)</h3>
              <p class="mt-1 text-[var(--text-muted)]">Transform one source asset into multi-format platform variants.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Engagement tracking dashboard</h3>
              <p class="mt-1 text-[var(--text-muted)]">Track growth signals and post performance in one place.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Monthly analytics report + growth review</h3>
              <p class="mt-1 text-[var(--text-muted)]">Review outcomes and iterate strategy based on hard data.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Ongoing management OR documented handoff to your team</h3>
              <p class="mt-1 text-[var(--text-muted)]">Choose delivery mode based on your team's execution capacity.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  {/* Social Proof Placeholder */}
  <section class="bg-[var(--surface-elevated)] py-16">
    <div class={CONTAINER_CLASSES.section}>
      <div class="mx-auto max-w-2xl">
        <blockquote class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-8 shadow-[var(--card-shadow)]">
          <div class="flex gap-1 text-[var(--accent-strong)]">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <p class="mt-4 text-lg italic text-[var(--text-strong)]">"Avaab built an AI-assisted content pipeline for our LinkedIn. We went from posting once a week to 5x a week without burning out our team. Impressions tripled in the first month."</p>
          <footer class="mt-4">
            <p class="text-sm font-semibold text-[var(--text-strong)]">— Rachel G.</p>
            <p class="text-sm text-[var(--text-muted)]">Marketing Manager, B2B Agency</p>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>
</ServiceLayout>
