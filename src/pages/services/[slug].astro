---
import { type CollectionEntry, getCollection } from "astro:content";
import Breadcrumb from "@components/Breadcrumb.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
  BUTTON_CLASSES,
  CONTAINER_CLASSES,
  TYPOGRAPHY_CLASSES,
} from "@lib/constants";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((service) => ({
    params: { slug: service.data.slug },
    props: { service },
  }));
}

interface Props {
  service: CollectionEntry<"services">;
}

const { service } = Astro.props;
const siteUrl = "https://ar10dev.github.io";
const canonicalUrl = new URL(
  `/services/${service.data.slug}/`,
  siteUrl,
).toString();

// Build structured data array with Service schema
const structuredDataArray: Record<string, unknown>[] = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": `${siteUrl}/services/${service.data.slug}/#service`,
    name: service.data.title,
    description: service.data.introduction,
    url: canonicalUrl,
    provider: {
      "@type": "Person",
      name: "Avaab Razzaq",
      jobTitle: "AI Growth Engineer",
      url: siteUrl,
      address: {
        "@type": "PostalAddress",
        addressLocality: "Miami",
        addressRegion: "Florida",
        addressCountry: "US",
      },
    },
    areaServed: [
      { "@type": "City", name: "Miami" },
      { "@type": "State", name: "Florida" },
      { "@type": "Country", name: "United States" },
    ],
    serviceType: service.data.services.map((s) => s.name),
  },
];

// Add FAQPage schema if FAQs exist
if (service.data.faqs && service.data.faqs.length > 0) {
  structuredDataArray.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: service.data.faqs.map((faq) => ({
      "@type": "Question",
      name: faq.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.answer,
      },
    })),
  });
}

// Combine into a single graph for cleaner output
const structuredData = {
  "@context": "https://schema.org",
  "@graph": structuredDataArray.map(({ "@context": _, ...rest }) => rest),
};

const serviceIcons: Record<string, string> = {
  chat: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  workflow: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4M2 12h4m12 0h4"/></svg>`,
  integration: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 3h5v5M4 20L21 3M21 16v5h-5M15 15l6 6M4 4l5 5"/></svg>`,
  document: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  app: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
  landing: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/></svg>`,
  cart: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>`,
  api: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>`,
  audit: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
  scale: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3v18h18"/><path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/></svg>`,
  conversion: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`,
  analytics: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 21H3V3"/><path d="M18 9l-5 6-4-4-3 4"/></svg>`,
};

// Get related services for internal linking
const allServices = await getCollection("services");
const relatedServices = service.data.relatedServices
  ? allServices.filter((s) =>
      service.data.relatedServices?.includes(s.data.slug),
    )
  : [];
---

<BaseLayout title={service.data.metaTitle} description={service.data.metaDescription} canonicalUrl={canonicalUrl} structuredData={structuredData}>
  <article class="min-h-screen">
    {/* Hero Section */}
    <section class="bg-[var(--surface-elevated)] py-16 md:py-24">
      <div class={CONTAINER_CLASSES.horizontal}>
        <Breadcrumb items={[
          { label: "Home", href: "/" },
          { label: "Services", href: "/services/" },
          { label: service.data.title }
        ]} class="mb-8" />
        
        <div class="max-w-4xl">
          <p class={TYPOGRAPHY_CLASSES.kicker}>Professional Service</p>
          <h1 class={`mt-3 ${TYPOGRAPHY_CLASSES.heroTitle}`}>{service.data.heroTitle}</h1>
          <p class={`mt-6 ${TYPOGRAPHY_CLASSES.subheading}`}>{service.data.heroSubtitle}</p>
          <p class={`mt-6 max-w-3xl ${TYPOGRAPHY_CLASSES.body}`}>{service.data.introduction}</p>
          
          <div class="mt-10 flex flex-wrap gap-4">
            <a href="/contact/" class={`${BUTTON_CLASSES.base} ${BUTTON_CLASSES.primary}`}>
              {service.data.cta.buttonText}
            </a>
            <a href="/portfolio/" class={`${BUTTON_CLASSES.base} ${BUTTON_CLASSES.secondary}`}>
              View Related Work
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Benefits Section */}
    <section class="py-16">
      <div class={CONTAINER_CLASSES.horizontal}>
        <h2 class={`text-center ${TYPOGRAPHY_CLASSES.sectionTitle}`}>Why Work With Me</h2>
        <div class="mt-12 grid gap-8 md:grid-cols-3">
          {service.data.benefits.map((benefit) => (
            <div class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-8 shadow-[var(--card-shadow)]">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <h3 class="text-lg font-bold text-[var(--text-strong)]">{benefit.title}</h3>
              <p class="mt-3 text-[var(--text-muted)]">{benefit.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Services Grid */}
    <section class="bg-[var(--surface-elevated)] py-16">
      <div class={CONTAINER_CLASSES.horizontal}>
        <h2 class={`text-center ${TYPOGRAPHY_CLASSES.sectionTitle}`}>What I Offer</h2>
        <div class="mt-12 grid gap-6 md:grid-cols-2">
          {service.data.services.map((item) => (
            <div class="flex gap-5 rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)]">
              <div class="flex-shrink-0 text-[var(--accent-strong)]" set:html={serviceIcons[item.icon] || serviceIcons.chat} />
              <div>
                <h3 class="text-lg font-bold text-[var(--text-strong)]">{item.name}</h3>
                <p class="mt-2 text-[var(--text-muted)]">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Technologies */}
    <section class="py-16">
      <div class={CONTAINER_CLASSES.horizontal}>
        <h2 class={`text-center ${TYPOGRAPHY_CLASSES.sectionTitle}`}>Technologies & Tools</h2>
        <div class="mt-10 flex flex-wrap justify-center gap-3">
          {service.data.technologies.map((tech) => (
            <span class="rounded-full border border-[var(--border-strong)] bg-[var(--surface-panel)] px-5 py-2.5 text-sm font-medium text-[var(--text-strong)]">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </section>

    {/* FAQ Section */}
    {service.data.faqs && service.data.faqs.length > 0 && (
      <section class="bg-[var(--surface-elevated)] py-16">
        <div class={CONTAINER_CLASSES.horizontal}>
          <h2 class={`text-center ${TYPOGRAPHY_CLASSES.sectionTitle}`}>Frequently Asked Questions</h2>
          <div class="mx-auto mt-12 max-w-3xl space-y-6">
            {service.data.faqs.map((faq) => (
              <details class="group rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] shadow-[var(--card-shadow)]">
                <summary class="flex cursor-pointer items-center justify-between p-6 text-lg font-bold text-[var(--text-strong)] [&::-webkit-details-marker]:hidden">
                  {faq.question}
                  <svg class="h-5 w-5 flex-shrink-0 text-[var(--accent-strong)] transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </summary>
                <div class="border-t border-[var(--card-uniform-border)] px-6 pb-6 pt-4">
                  <p class="text-[var(--text-muted)] leading-relaxed">{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* Related Services */}
    {relatedServices.length > 0 && (
      <section class="py-16">
        <div class={CONTAINER_CLASSES.horizontal}>
          <h2 class={`text-center ${TYPOGRAPHY_CLASSES.sectionTitle}`}>Related Services</h2>
          <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {relatedServices.map((related) => (
              <a 
                href={`/services/${related.data.slug}/`}
                class="group rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)] transition-all hover:-translate-y-1 hover:shadow-lg"
              >
                <h3 class="text-lg font-bold text-[var(--text-strong)] group-hover:text-[var(--accent-strong)] transition-colors">
                  {related.data.title}
                </h3>
                <p class="mt-2 text-sm text-[var(--text-muted)] line-clamp-2">
                  {related.data.heroSubtitle}
                </p>
                <span class="mt-4 inline-flex items-center text-sm font-semibold text-[var(--accent-strong)]">
                  Learn more →
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* CTA Section */}
    <section class="bg-[var(--surface-elevated)] py-16">
      <div class={CONTAINER_CLASSES.horizontal}>
        <div class="mx-auto max-w-2xl text-center">
          <h2 class={TYPOGRAPHY_CLASSES.sectionTitle}>{service.data.cta.title}</h2>
          <p class={`mt-4 ${TYPOGRAPHY_CLASSES.body}`}>{service.data.cta.description}</p>
          <a href={service.data.cta.buttonLink} class={`mt-8 ${BUTTON_CLASSES.base} ${BUTTON_CLASSES.primary}`}>
            {service.data.cta.buttonText}
          </a>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
