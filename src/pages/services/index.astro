---
import { getCollection } from "astro:content";
import Breadcrumb from "@components/Breadcrumb.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
  BUTTON_CLASSES,
  CONTAINER_CLASSES,
  TYPOGRAPHY_CLASSES,
} from "@lib/constants";

const title = "AI Automation, Web & SEO Services in Miami | Avaab Razzaq";
const description =
  "Explore AI automation, full-stack web and mobile development, and technical SEO services by Avaab Razzaq in Miami, built to improve conversions and growth.";

const allServices = await getCollection("services");

const serviceOrder = [
  "full-stack-web-development",
  "ai-agent-development",
  "ai-automation",
  "saas-mvp-development",
  "mobile-app-development",
  "ai-chatbot-development",
  "ai-workflow-automation",
  "llm-integration",
  "prompt-engineering",
  "seo-growth",
  "technical-seo-audit",
  "conversion-optimization",
  "social-media-growth",
  "programmatic-seo",
];

const services = allServices.sort((a, b) => {
  const aIndex = serviceOrder.indexOf(a.data.slug);
  const bIndex = serviceOrder.indexOf(b.data.slug);
  // Put unknown services at the end
  const aOrder = aIndex === -1 ? 999 : aIndex;
  const bOrder = bIndex === -1 ? 999 : bIndex;
  return aOrder - bOrder;
});

const siteUrl = new URL(Astro.site?.toString() ?? "https://avaabrazzaq.com")
  .origin;
const canonicalUrl = new URL("/services/", siteUrl).toString();

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: "Avaab Razzaq - AI Growth Engineer",
      description:
        "AI Growth Engineer specializing in web apps, AI automation, and technical SEO",
      publisher: { "@id": `${siteUrl}/#person` },
    },
    {
      "@type": "CollectionPage",
      "@id": canonicalUrl,
      url: canonicalUrl,
      name: title,
      description: description,
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: {
        "@type": "ProfessionalService",
        "@id": `${siteUrl}/#services`,
        name: "AI Growth Engineering Services",
        provider: { "@id": `${siteUrl}/#person` },
        hasOfferCatalog: {
          "@type": "OfferCatalog",
          name: "Professional Services",
          itemListElement: services.map((service, index) => ({
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: service.data.title,
              description: service.data.introduction,
              url: `${siteUrl}/services/${service.data.slug}/`,
            },
            position: index + 1,
          })),
        },
      },
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      name: "Avaab Razzaq",
      url: siteUrl,
      jobTitle: "AI Growth Engineer",
      sameAs: [
        "https://github.com/AR10Dev",
        "https://linkedin.com/in/avaabrazzaq",
        "https://twitter.com/itsmeAvaab",
      ],
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonicalUrl}#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: `${siteUrl}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Services",
        },
      ],
    },
  ],
};

const serviceIcons: Record<string, string> = {
  "ai-agent-development": `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4m0 14v4M1 12h4m14 0h4M4.9 4.9l2.8 2.8m8.6 8.6l2.8 2.8M4.9 19.1l2.8-2.8m8.6-8.6l2.8-2.8"/><path d="M12 9v3l2 2"/></svg>`,
  "ai-automation": `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4M2 12h4m12 0h4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/></svg>`,
  "full-stack-web-development": `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
  "seo-growth": `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/></svg>`,
  "ai-workflow-automation": `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4M2 12h4m12 0h4"/></svg>`,
  "ai-chatbot-development": `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  "llm-integration": `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3h5v5M4 20L21 3M21 16v5h-5M15 15l6 6M4 4l5 5"/></svg>`,
  "prompt-engineering": `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`,
  "technical-seo-audit": `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
  "programmatic-seo": `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/></svg>`,
  "conversion-optimization": `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`,
  "saas-mvp-development": `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
  "social-media-growth": `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 5.8c-.7.3-1.4.5-2.2.6a3.8 3.8 0 0 0 1.7-2.1c-.7.4-1.6.8-2.5 1a3.8 3.8 0 0 0-6.5 3.5 10.8 10.8 0 0 1-7.8-4 3.8 3.8 0 0 0 1.2 5.1c-.6 0-1.1-.2-1.6-.4v.1a3.8 3.8 0 0 0 3 3.7c-.5.1-1 .1-1.5.1-.4 0-.7 0-1.1-.1a3.8 3.8 0 0 0 3.5 2.6 7.7 7.7 0 0 1-4.8 1.6H3a10.9 10.9 0 0 0 5.9 1.7c7.1 0 11-5.8 11-10.9v-.5c.8-.5 1.5-1.2 2.1-2Z"/></svg>`,
  "mobile-app-development": `<svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>`,
};
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl} ogImage="https://avaabrazzaq.com/og-services.png" structuredData={structuredData}>
  <div class="min-h-screen py-12">
    <div class={CONTAINER_CLASSES.section}>
      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Services" }]} class="mb-8" />
      
      <header class="mb-16 text-center">
        <p class={TYPOGRAPHY_CLASSES.kicker}>Avaab Razzaq - AI Growth Engineer</p>
        <h1 class={`mt-3 ${TYPOGRAPHY_CLASSES.heroTitle}`}>Web Apps, AI Automation & Technical SEO Services</h1>
        <p class={`mt-6 mx-auto max-w-3xl ${TYPOGRAPHY_CLASSES.body}`}>
          As an AI growth engineer based in Miami, Florida, I help businesses build scalable web apps, implement AI automation to streamline operations, and drive SEO growth through technical SEO strategies. My growth engineer services are designed to deliver measurable business results for clients across the United States.
        </p>
      </header>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <article class="group relative flex flex-col rounded-2xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-8 shadow-[var(--card-shadow)] transition-all hover:-translate-y-1 hover:shadow-xl">
            <div class="mb-6 text-[var(--accent-strong)]" set:html={serviceIcons[service.data.slug] || serviceIcons["ai-automation"]} />
            
            <h2 class={`${TYPOGRAPHY_CLASSES.cardTitle} font-bold mb-3`}>
              <a
                href={`/services/${service.data.slug}/`}
                data-track={`open_service_detail_${service.data.slug}`}
                class="after:absolute after:inset-0"
              >
                {service.data.title}
              </a>
            </h2>
            
            <p class={`${TYPOGRAPHY_CLASSES.cardBodyMuted} mb-6 flex-grow`}>
              {service.data.heroSubtitle}
            </p>

            <div class="mb-6 flex flex-wrap gap-2">
              {service.data.technologies.slice(0, 4).map((tech) => (
                <span class="rounded-full bg-[var(--surface-elevated)] px-3 py-1 text-xs font-medium text-[var(--text-muted)]">
                  {tech}
                </span>
              ))}
            </div>

            <div class="flex items-center justify-between">
              <span class="text-sm font-semibold text-[var(--accent-strong)] group-hover:underline">
                Learn more →
              </span>
            </div>
          </article>
        ))}
      </div>

      <section class="mt-16 rounded-2xl border border-[var(--card-uniform-border)] bg-[var(--surface-elevated)] p-8 shadow-[var(--card-shadow)]">
        <h2 class={TYPOGRAPHY_CLASSES.sectionTitle}>Featured Implementation Deep Dives</h2>
        <p class={`mt-4 max-w-3xl ${TYPOGRAPHY_CLASSES.body}`}>
          Review how these services translate into measurable outcomes. These linked pages include process details,
          technology choices, and performance metrics from real delivery work.
        </p>
        <div class="mt-8 grid gap-4 md:grid-cols-3">
          <a href="/services/mobile-app-development/" class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-5 transition-colors hover:border-[var(--accent-strong)]/40">
            <h3 class="font-bold text-[var(--text-strong)]">Mobile App Development Service</h3>
            <p class="mt-2 text-sm text-[var(--text-muted)]">Flutter and native iOS/Android delivery process with launch support.</p>
          </a>
          <a href="/portfolio/ai-workflow-automation/" class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-5 transition-colors hover:border-[var(--accent-strong)]/40">
            <h3 class="font-bold text-[var(--text-strong)]">AI Workflow Automation Case Study</h3>
            <p class="mt-2 text-sm text-[var(--text-muted)]">Multi-agent lead routing and CRM enrichment with quantified efficiency gains.</p>
          </a>
          <a href="/portfolio/social-media-management/" class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-5 transition-colors hover:border-[var(--accent-strong)]/40">
            <h3 class="font-bold text-[var(--text-strong)]">Social Media Growth Case Study</h3>
            <p class="mt-2 text-sm text-[var(--text-muted)]">Cross-channel content operations with audience growth and lead attribution metrics.</p>
          </a>
        </div>
      </section>

      <section class="mt-20 rounded-2xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-10 text-center shadow-[var(--card-shadow)]">
        <h2 class={TYPOGRAPHY_CLASSES.sectionTitle}>Hire an AI Growth Engineer in Miami, Florida</h2>
        <p class={`mt-4 mx-auto max-w-2xl ${TYPOGRAPHY_CLASSES.body}`}>
          Whether you need AI automation systems, high-performance web apps, or technical SEO strategy, 
          I'm here to help you achieve your business goals. As a growth engineer based in Miami, Florida, I deliver web apps, AI growth solutions, and SEO growth strategies that drive measurable results.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href="/contact/" data-track="services_cta_discovery_call" class={`${BUTTON_CLASSES.base} ${BUTTON_CLASSES.primary}`}>
            Schedule a Discovery Call
          </a>
          <a href="/portfolio/" data-track="services_cta_view_work" class={`${BUTTON_CLASSES.base} ${BUTTON_CLASSES.secondary}`}>
            View My Work
          </a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
