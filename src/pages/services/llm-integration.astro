---
import ServiceLayout from "@layouts/ServiceLayout.astro";
import { CONTAINER_CLASSES, TYPOGRAPHY_CLASSES } from "@lib/constants";

const faqs = [
  {
    question: "Which LLM should I use — Claude, GPT-4, or open-source?",
    answer:
      "It depends on your use case, budget, and data privacy requirements. Claude excels at long-context reasoning and instruction following. GPT-4 has the widest ecosystem. Open-source (Llama, Mistral) is best when data must stay on-premise. I'll recommend the right fit after a requirements call.",
  },
  {
    question: "Can you reduce our current AI API costs?",
    answer:
      "Yes. Most teams overspend by using frontier models for tasks that smaller, cheaper models handle just as well. I audit your usage and implement tiered model routing to cut costs 30–70% without quality loss.",
  },
  {
    question: "What is function calling / tool use?",
    answer:
      "It's a feature that lets LLMs trigger structured actions — like querying a database, calling an API, or updating a record — instead of just generating text. It's how you build truly agentic AI systems.",
  },
  {
    question: "How is this different from your AI automation service?",
    answer:
      "AI automation focuses on workflow pipelines (n8n, Make). LLM integration focuses on embedding AI into your codebase — adding AI capabilities directly to your product or internal tools at the API level.",
  },
];
---

<ServiceLayout
  title="LLM Integration & API Developer for Hire | Avaab Razzaq"
  description="Hire an LLM integration developer. I connect Claude, OpenAI, Llama, and Mistral to your existing tools, databases, and workflows — making your systems AI-native."
  heroHeadline="Make Your Existing Tools AI-Native"
  heroSubheadline="I integrate large language models — Claude, GPT-4, Llama — directly into your existing products, databases, and workflows so AI becomes a core capability, not an afterthought."
  ctaText="Discuss Your Integration"
  ctaHref="/contact/"
  serviceName="LLM Integration & API Consulting"
  serviceDescription="LLM integration and API consulting for businesses. Connect Claude, OpenAI GPT-4, Llama, and Mistral to your existing tools, databases, and workflows."
  keywords={["LLM integration developer", "Claude API integration", "OpenAI API developer for hire", "LLM API consulting", "AI integration services"]}
  publishedTime="2025-02-25"
  modifiedTime="2026-04-08"
  faqs={faqs}
>
  {/* Problem Section */}
  <section class="py-16">
    <div class={CONTAINER_CLASSES.section}>
      <div class="max-w-3xl">
        <p class={TYPOGRAPHY_CLASSES.kicker}>The Problem</p>
        <h2 class={`mt-3 ${TYPOGRAPHY_CLASSES.sectionTitle}`}>The Gap Between ChatGPT and AI-Native Products</h2>
        <div class={`mt-6 space-y-4 ${TYPOGRAPHY_CLASSES.body}`}>
          <p>
            Most businesses know they should be using AI but don't know where it fits in their existing stack. 
            The gap between "we use ChatGPT manually" and "AI is embedded in our product and processes" is an engineering gap.
          </p>
          <p>
            It costs companies months of productivity and competitive advantage every day they wait.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Solution Section */}
  <section class="bg-[var(--surface-elevated)] py-16">
    <div class={CONTAINER_CLASSES.section}>
      <div class="max-w-3xl">
        <p class={TYPOGRAPHY_CLASSES.kicker}>The Solution</p>
        <h2 class={`mt-3 ${TYPOGRAPHY_CLASSES.sectionTitle}`}>LLM Integration at the API Level</h2>
        <div class={`mt-6 space-y-4 ${TYPOGRAPHY_CLASSES.body}`}>
          <p>
            I audit your existing tools and identify the highest-leverage points for LLM integration. Then I build: 
            API wrappers and prompt pipelines, structured output parsers, RAG systems, streaming interfaces, 
            function calling setups, and cost-optimization layers.
          </p>
          <p>
            I work with Claude (Anthropic), OpenAI GPT-4, and open-source models (Llama, Mistral) via Ollama or cloud inference.
          </p>
        </div>
        <div class="mt-8 grid gap-4 md:grid-cols-2">
          <div class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)]">
            <h3 class="text-lg font-bold text-[var(--text-strong)]">Claude & OpenAI APIs</h3>
            <p class="mt-2 text-[var(--text-muted)]">Latest frontier models with best-in-class reasoning and instruction following.</p>
          </div>
          <div class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)]">
            <h3 class="text-lg font-bold text-[var(--text-strong)]">Open-Source Models</h3>
            <p class="mt-2 text-[var(--text-muted)]">Llama, Mistral via Ollama or cloud inference for on-premise needs.</p>
          </div>
          <div class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)]">
            <h3 class="text-lg font-bold text-[var(--text-strong)]">Function Calling</h3>
            <p class="mt-2 text-[var(--text-muted)]">Let LLMs trigger structured actions in your systems.</p>
          </div>
          <div class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)]">
            <h3 class="text-lg font-bold text-[var(--text-strong)]">RAG + Vector Search</h3>
            <p class="mt-2 text-[var(--text-muted)]">Ground LLM outputs in your actual data and documentation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* What's Included Section */}
  <section class="py-16">
    <div class={CONTAINER_CLASSES.section}>
      <div class="max-w-3xl">
        <p class={TYPOGRAPHY_CLASSES.kicker}>What's Included</p>
        <h2 class={`mt-3 ${TYPOGRAPHY_CLASSES.sectionTitle}`}>Full LLM Integration Package</h2>
        <ul class="mt-8 space-y-4">
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Integration Audit + Opportunity Mapping</h3>
              <p class="mt-1 text-[var(--text-muted)]">Identify where LLMs will have the highest impact in your stack.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Model Selection + Cost Analysis</h3>
              <p class="mt-1 text-[var(--text-muted)]">Choose the right model for your use case and budget.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Prompt Engineering + System Design</h3>
              <p class="mt-1 text-[var(--text-muted)]">Craft prompts that reliably produce the outputs you need.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">API Integration Development</h3>
              <p class="mt-1 text-[var(--text-muted)]">Build the connection between your systems and LLM APIs.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Structured Output + Parsing Pipelines</h3>
              <p class="mt-1 text-[var(--text-muted)]">Extract reliable, structured data from LLM outputs.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">RAG Setup (Vector DB + Retrieval)</h3>
              <p class="mt-1 text-[var(--text-muted)]">Ground LLM responses in your actual documentation.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Streaming Interfaces</h3>
              <p class="mt-1 text-[var(--text-muted)]">Real-time token streaming for responsive UX.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Token Cost Optimization</h3>
              <p class="mt-1 text-[var(--text-muted)]">Tiered model routing to minimize costs without quality loss.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Testing + Evals</h3>
              <p class="mt-1 text-[var(--text-muted)]">Systematic evaluation of LLM outputs for quality assurance.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Documentation</h3>
              <p class="mt-1 text-[var(--text-muted)]">Clear documentation for your team to maintain and extend.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  {/* Social Proof Placeholder */}
  <section class="bg-[var(--surface-elevated)] py-16">
    <div class={CONTAINER_CLASSES.section}>
      <div class="mx-auto max-w-2xl">
        <blockquote class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-8 shadow-[var(--card-shadow)]">
          <div class="flex gap-1 text-[var(--accent-strong)]">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <p class="mt-4 text-lg italic text-[var(--text-strong)]">"Avaab integrated Claude directly into our internal dashboard. Our analysts can now query months of data in plain English and get structured summaries in seconds. The ROI was immediate."</p>
          <footer class="mt-4">
            <p class="text-sm font-semibold text-[var(--text-strong)]">— Sophie L.</p>
            <p class="text-sm text-[var(--text-muted)]">Director of Analytics, Media Company</p>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>
</ServiceLayout>
