---
import ServiceLayout from "@layouts/ServiceLayout.astro";
import { CONTAINER_CLASSES, TYPOGRAPHY_CLASSES } from "@lib/constants";

const faqs = [
  {
    question: "What makes Astro better than Next.js for my site?",
    answer:
      "For content-heavy sites (marketing, portfolio, docs, blogs), Astro beats Next.js on performance because it ships zero JS by default. Next.js is better for highly interactive web apps. I'll tell you which is right for your project — including if neither is the right choice.",
  },
  {
    question: "Can you migrate my existing site to Astro?",
    answer:
      "Yes. I handle full migrations from WordPress, Webflow, Next.js, or any existing stack to Astro, with no SEO regression.",
  },
  {
    question: "Can you integrate a CMS?",
    answer:
      "Yes — Astro works great with headless CMS options like Contentful, Sanity, and Notion, or with Astro DB for simpler setups. Your team can edit content without touching code.",
  },
  {
    question: "How fast will my site be?",
    answer:
      "Astro sites I build consistently score 95–100 on Google Lighthouse for performance. Sub-1-second load times are achievable on most content pages with proper image optimization and caching.",
  },
];
---

<ServiceLayout
  title="Astro Web Developer for Hire — Lightning-Fast Websites | Avaab Razzaq"
  description="Hire an Astro.js developer to build lightning-fast websites that rank higher and convert better. I build Astro sites with TailwindCSS, SolidJS, and TypeScript for maximum performance and SEO."
  heroHeadline="Build the Fastest Website Your Competitors Can't Match"
  heroSubheadline="I specialize in Astro.js development — building websites that score 95–100 on Lighthouse, load in under 1 second, and are architected from the ground up for SEO and conversion."
  ctaText="Discuss Your Project"
  ctaHref="/contact/"
  serviceName="Astro Web Development"
  serviceDescription="Expert Astro.js web development for businesses and founders who want maximum performance, SEO, and conversion. Built with TailwindCSS, SolidJS, and TypeScript."
  keywords={["Astro developer for hire", "Astro.js web development", "hire Astro developer", "fast website development", "performance web development"]}
  faqs={faqs}
>
  {/* Problem Section */}
  <section class="py-16">
    <div class={CONTAINER_CLASSES.horizontal}>
      <div class="max-w-3xl">
        <p class={TYPOGRAPHY_CLASSES.kicker}>The Problem</p>
        <h2 class={`mt-3 ${TYPOGRAPHY_CLASSES.sectionTitle}`}>Most Websites Are Built With the Wrong Tool</h2>
        <div class={`mt-6 space-y-4 ${TYPOGRAPHY_CLASSES.body}`}>
          <p>
            Most websites are built with the wrong tool for the job. React-heavy sites that load 4MB of JavaScript for a marketing page. 
            WordPress sites bloated with plugins. Next.js apps with hydration overhead on pages that don't need interactivity.
          </p>
          <p>
            The result: slow Core Web Vitals, poor SEO scores, and visitors who bounce before your content even loads.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Solution Section */}
  <section class="bg-[var(--surface-elevated)] py-16">
    <div class={CONTAINER_CLASSES.horizontal}>
      <div class="max-w-3xl">
        <p class={TYPOGRAPHY_CLASSES.kicker}>The Solution</p>
        <h2 class={`mt-3 ${TYPOGRAPHY_CLASSES.sectionTitle}`}>Astro: Zero JS by Default, Maximum Performance</h2>
        <div class={`mt-6 space-y-4 ${TYPOGRAPHY_CLASSES.body}`}>
          <p>
            Astro is the right framework for content-heavy, performance-critical websites. It ships zero JavaScript by default 
            and only hydrates the components that need interactivity.
          </p>
          <p>
            I build Astro sites with TailwindCSS for styling, SolidJS for interactive islands, TypeScript throughout, and full 
            technical SEO baked in from day one — structured data, sitemap, meta tags, image optimization.
          </p>
        </div>
        <div class="mt-8 grid gap-4 md:grid-cols-2">
          <div class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)]">
            <h3 class="text-lg font-bold text-[var(--text-strong)]">Zero JS by Default</h3>
            <p class="mt-2 text-[var(--text-muted)]">Astro ships no JavaScript unless a component needs it.</p>
          </div>
          <div class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)]">
            <h3 class="text-lg font-bold text-[var(--text-strong)]">TailwindCSS Design System</h3>
            <p class="mt-2 text-[var(--text-muted)]">Utility-first styling for fast, maintainable design.</p>
          </div>
          <div class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)]">
            <h3 class="text-lg font-bold text-[var(--text-strong)]">SolidJS Islands</h3>
            <p class="mt-2 text-[var(--text-muted)]">Lightweight interactivity where you need it.</p>
          </div>
          <div class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)]">
            <h3 class="text-lg font-bold text-[var(--text-strong)]">Technical SEO Built-In</h3>
            <p class="mt-2 text-[var(--text-muted)]">Structured data, sitemap, meta tags from day one.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* What's Included Section */}
  <section class="py-16">
    <div class={CONTAINER_CLASSES.horizontal}>
      <div class="max-w-3xl">
        <p class={TYPOGRAPHY_CLASSES.kicker}>What's Included</p>
        <h2 class={`mt-3 ${TYPOGRAPHY_CLASSES.sectionTitle}`}>Full Astro Development Package</h2>
        <ul class="mt-8 space-y-4">
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Discovery + Architecture Planning</h3>
              <p class="mt-1 text-[var(--text-muted)]">Define site structure, features, and technical requirements.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Astro Project Setup + Configuration</h3>
              <p class="mt-1 text-[var(--text-muted)]">Proper project structure with TypeScript and best practices.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Responsive UI/UX Implementation</h3>
              <p class="mt-1 text-[var(--text-muted)]">Beautiful, responsive design that works on all devices.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">TailwindCSS Design System</h3>
              <p class="mt-1 text-[var(--text-muted)]">Consistent, maintainable styling with utility classes.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">SolidJS Interactive Components</h3>
              <p class="mt-1 text-[var(--text-muted)]">Lightweight interactivity where needed using Astro islands.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Technical SEO Foundation</h3>
              <p class="mt-1 text-[var(--text-muted)]">Structured data, sitemap, meta tags, image optimization.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Performance Optimization (95+ Lighthouse)</h3>
              <p class="mt-1 text-[var(--text-muted)]">Targeting 95–100 on Google Lighthouse performance.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">CMS Integration (If Needed)</h3>
              <p class="mt-1 text-[var(--text-muted)]">Astro DB, Contentful, Sanity — your team can edit content.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Deployment (Netlify / Vercel / Cloudflare Pages)</h3>
              <p class="mt-1 text-[var(--text-muted)]">Production deployment with CI/CD and edge caching.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[var(--accent-strong)]/10 text-[var(--accent-strong)]">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--text-strong)]">Post-Launch Support</h3>
              <p class="mt-1 text-[var(--text-muted)]">Bug fixes and adjustments after your site goes live.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  {/* Social Proof Placeholder */}
  <section class="bg-[var(--surface-elevated)] py-16">
    <div class={CONTAINER_CLASSES.horizontal}>
      <div class="mx-auto max-w-2xl">
        <blockquote class="rounded-xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-8 shadow-[var(--card-shadow)]">
          <div class="flex gap-1 text-[var(--accent-strong)]">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <p class="mt-4 text-lg italic text-[var(--text-strong)]">"[Client testimonial will go here]"</p>
          <footer class="mt-4">
            <p class="text-sm font-semibold text-[var(--text-strong)]">— Client Name</p>
            <p class="text-sm text-[var(--text-muted)]">Title, Company</p>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>
</ServiceLayout>
