---
import { getCollection } from "astro:content";
import Breadcrumb from "@components/Breadcrumb.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { BUTTON_CLASSES, CONTAINER_CLASSES, TYPOGRAPHY_CLASSES } from "@lib/constants";

const title = "Portfolio & Case Studies | Avaab Razzaq - AI Growth Engineer";
const description = "Explore proof-of-concept builds and case studies in AI automation, full-stack development, and SEO growth. Work samples from a Miami-based engineer serving clients across the US.";

const siteUrl = "https://ar10dev.github.io";
const canonicalUrl = new URL("/portfolio/", siteUrl).toString();

const portfolioItems = (await getCollection("portfolio")).sort(
  (a, b) => a.data.order - b.data.order,
);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${siteUrl}/portfolio/#collection`,
  name: "Portfolio & Case Studies",
  description: description,
  url: canonicalUrl,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: portfolioItems.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "SoftwareApplication",
        name: item.data.title,
        applicationCategory: item.data.category,
        description: item.data.summary,
        url: `${siteUrl}/portfolio/${item.id}/`,
      },
    })),
  },
  author: {
    "@type": "Person",
    name: "Avaab Razzaq",
    url: siteUrl,
  },
};

const categoryColors: Record<string, string> = {
  "Automation": "bg-purple-500/10 text-purple-600 border-purple-500/20",
  "Development": "bg-blue-500/10 text-blue-600 border-blue-500/20",
  "SEO": "bg-green-500/10 text-green-600 border-green-500/20",
  "Marketing": "bg-orange-500/10 text-orange-600 border-orange-500/20",
  "Analytics": "bg-cyan-500/10 text-cyan-600 border-cyan-500/20",
};
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl} structuredData={structuredData}>
  <div class="min-h-screen py-12">
    <div class={CONTAINER_CLASSES.horizontal}>
      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Portfolio" }]} class="mb-8" />
      
      <header class="mb-16 text-center">
        <p class={TYPOGRAPHY_CLASSES.kicker}>My Work</p>
        <h1 class={`mt-3 ${TYPOGRAPHY_CLASSES.heroTitle}`}>Portfolio & Case Studies</h1>
        <p class={`mt-6 mx-auto max-w-3xl ${TYPOGRAPHY_CLASSES.body}`}>
          Proof-of-concept builds and engineered demos that show exactly what I can build and deploy. 
          Each project demonstrates practical solutions for real business challenges.
        </p>
      </header>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {portfolioItems.map((item) => (
          <article 
            class="group flex flex-col rounded-2xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-6 shadow-[var(--card-shadow)] transition-all hover:-translate-y-1 hover:shadow-xl"
            itemscope
            itemtype="https://schema.org/SoftwareApplication"
          >
            <div class="mb-4 flex items-center justify-between">
              <span class={`inline-block rounded-full border px-3 py-1 text-xs font-semibold ${categoryColors[item.data.category] || categoryColors["Development"]}`} itemprop="applicationCategory">
                {item.data.category}
              </span>
              <span class="text-xs text-[var(--text-muted)]">{item.data.timeframe}</span>
            </div>

            <h2 class="text-xl font-bold text-[var(--text-strong)]" itemprop="name">
              <a href={`/portfolio/${item.id}/`} class="hover:text-[var(--accent-strong)] transition-colors">
                {item.data.title}
              </a>
            </h2>

            <p class="mt-3 text-[var(--text-muted)] flex-grow" itemprop="description">
              {item.data.summary}
            </p>

            <div class="mt-4 pt-4 border-t border-[var(--border-strong)]">
              <p class="text-xs font-semibold uppercase tracking-wider text-[var(--accent-strong)] mb-2">Tech Stack</p>
              <div class="flex flex-wrap gap-1.5">
                {item.data.stack.map((tech) => (
                  <span class="rounded bg-[var(--surface-elevated)] px-2 py-0.5 text-xs text-[var(--text-muted)]">
                    {tech}
                  </span>
                ))}
              </div>
            </div>

            <div class="mt-6 flex items-center justify-between">
              <a 
                href={`/portfolio/${item.id}/`}
                class="text-sm font-semibold text-[var(--accent-strong)] hover:underline"
              >
                View details →
              </a>
              <a 
                href={item.data.proofUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs text-[var(--text-muted)] hover:text-[var(--accent-strong)]"
                aria-label={`${item.data.proofLabel} for ${item.data.title} (opens in new tab)`}
              >
                {item.data.proofLabel} ↗
              </a>
            </div>
          </article>
        ))}
      </div>

      <section class="mt-20 rounded-2xl border border-[var(--card-uniform-border)] bg-[var(--card-uniform-bg)] p-10 text-center shadow-[var(--card-shadow)]">
        <h2 class={TYPOGRAPHY_CLASSES.sectionTitle}>Have a Project in Mind?</h2>
        <p class={`mt-4 mx-auto max-w-2xl ${TYPOGRAPHY_CLASSES.body}`}>
          Whether you need AI automation, a high-performance web app, or SEO strategy, 
          I can build a solution tailored to your business needs.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href="/contact/" class={`${BUTTON_CLASSES.base} ${BUTTON_CLASSES.primary}`}>
            Start a Conversation
          </a>
          <a href="/services/" class={`${BUTTON_CLASSES.base} ${BUTTON_CLASSES.secondary}`}>
            View Services
          </a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
