---
import AnalyticsConsent from "@components/AnalyticsConsent.astro";
import FooterNav from "@components/FooterNav.astro";
import GoogleAnalytics from "@components/GoogleAnalytics.astro";
import HeaderNav from "@components/HeaderNav.astro";
import HeadSEO from "@components/HeadSEO.astro";
import { getAnalyticsConfig } from "@lib/analytics";
import { buildSiteUrl, normalizeCanonicalUrl } from "@lib/canonicalUrl";
import { themeInitScript } from "@scripts/themeInit";
import "../styles/global.css";
import "../styles/diagrams.css";

type Props = {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: "website" | "article" | "profile";
  structuredData?: Record<string, unknown>;
  noIndex?: boolean;
  keywords?: string;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  robots?: string;
  readingTime?: string;
};

const siteUrl = buildSiteUrl(Astro.site);

const {
  title,
  description,
  canonicalUrl: canonicalUrlProp,
  ogImage = new URL("/og-ai-growth-engineer.png", siteUrl).toString(),
  ogType = "website",
  structuredData,
  noIndex = false,
  keywords,
  publishedTime,
  modifiedTime,
  author = "Avaab Razzaq",
  robots,
} = Astro.props as Props;

const canonicalUrl = normalizeCanonicalUrl(
  canonicalUrlProp ?? Astro.url.pathname,
  siteUrl,
);
const finalOgImage = ogImage.startsWith("http")
  ? ogImage
  : new URL(ogImage, siteUrl).toString();

const defaultKeywords =
  "AI Growth Engineer, AI Automation, Full-Stack Developer, SEO Expert, Miami Florida, Web Development, LLM Integration, Workflow Automation";
const finalKeywords = keywords || defaultKeywords;
const defaultRobots =
  "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const resolvedRobots =
  robots ?? (noIndex ? "noindex, nofollow" : defaultRobots);
const { gaMeasurementId, shouldLoadAnalytics } = getAnalyticsConfig();

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    {shouldLoadAnalytics && (
      <>
        <!-- Google Analytics -->
        <GoogleAnalytics id={gaMeasurementId} />
      </>
    )}
    <HeadSEO
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={finalOgImage}
      ogType={ogType}
      author={author}
      robots={resolvedRobots}
      keywords={finalKeywords}
      structuredData={structuredData}
    />

    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <script is:inline set:html={themeInitScript}></script>
  </head>
  <body class="min-h-screen bg-transparent text-[var(--text-strong)]">
    <div aria-hidden="true" class="fixed inset-0 -z-10 pointer-events-none site-bg"></div>
    
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[200] focus:rounded-lg focus:border focus:border-[var(--border-strong)] focus:bg-[var(--surface-panel)] focus:px-4 focus:py-2 focus:font-bold focus:text-[var(--text-strong)]">
      Skip to main content
    </a>

    <HeaderNav currentPath={currentPath} />

    <main id="main-content" class="pt-20" tabindex="-1">
      <slot />
    </main>

    <FooterNav />

    {shouldLoadAnalytics && <AnalyticsConsent />}

    <script>
      import "../scripts/code-copy.ts";
      import "../scripts/homepage.ts";
    </script>
  </body>
</html>
