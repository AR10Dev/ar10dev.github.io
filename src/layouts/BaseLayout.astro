---
import AnalyticsConsent from "@components/AnalyticsConsent.astro";
import CalEmbed from "@components/CalEmbed.astro";
import FooterNav from "@components/FooterNav.astro";
import GoogleAnalytics from "@components/GoogleAnalytics.astro";
import HeaderNav from "@components/HeaderNav.astro";
import HeadSEO from "@components/HeadSEO.astro";
import { getAnalyticsConfig } from "@lib/analytics";
import { buildSiteUrl, normalizeCanonicalUrl } from "@lib/canonicalUrl";
import {
  DEFAULT_META_KEYWORDS,
  DEFAULT_OG_IMAGE,
  DEFAULT_ROBOTS,
  PERSON_NAME,
  resolveAbsoluteUrl,
} from "@lib/siteMeta";
import { themeInitScript } from "@scripts/themeInit";
import "../styles/global.css";
import "../styles/diagrams.css";

type Props = {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: "website" | "article" | "profile";
  articleSection?: string;
  structuredData?: Record<string, unknown>;
  noIndex?: boolean;
  keywords?: string;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  robots?: string;
  readingTime?: string;
  loadCodeCopy?: boolean;
};

const siteUrl = buildSiteUrl(Astro.site);

const {
  title,
  description,
  canonicalUrl: canonicalUrlProp,
  ogImage = DEFAULT_OG_IMAGE,
  ogType = "website",
  articleSection,
  structuredData,
  noIndex = false,
  keywords,
  publishedTime,
  modifiedTime,
  readingTime,
  author = PERSON_NAME,
  robots,
  loadCodeCopy = false,
} = Astro.props as Props;

const canonicalUrl = normalizeCanonicalUrl(
  canonicalUrlProp ?? Astro.url.pathname,
  siteUrl,
);
const finalOgImage = resolveAbsoluteUrl(ogImage, siteUrl);
const finalKeywords = keywords || DEFAULT_META_KEYWORDS;
const resolvedRobots =
  robots ?? (noIndex ? "noindex, nofollow" : DEFAULT_ROBOTS);
const { gaMeasurementId, shouldLoadAnalytics } = getAnalyticsConfig();

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {shouldLoadAnalytics && (
      <>
        <!-- Google Analytics -->
        <GoogleAnalytics id={gaMeasurementId} />
      </>
    )}
    <HeadSEO
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={finalOgImage}
      ogType={ogType}
      author={author}
      robots={resolvedRobots}
      keywords={finalKeywords}
      readingTime={readingTime}
      structuredData={structuredData}
    />

    <!-- PWA manifest and iOS support tags for reliable install detection. -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#000000" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="AR10" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <slot name="head" />

    {ogType === "article" && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === "article" && <meta property="article:author" content={author} />}
    {ogType === "article" && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {ogType === "article" && articleSection && <meta property="article:section" content={articleSection} />}

    <script is:inline set:html={themeInitScript}></script>
  </head>
  <body class="min-h-screen bg-transparent text-[var(--text-strong)]">
    <div aria-hidden="true" class="fixed inset-0 -z-10 pointer-events-none site-bg"></div>
    
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[200] focus:rounded-lg focus:border focus:border-[var(--border-strong)] focus:bg-[var(--surface-panel)] focus:px-4 focus:py-2 focus:font-bold focus:text-[var(--text-strong)]">
      Skip to main content
    </a>

    <HeaderNav currentPath={currentPath} />

    <main id="main-content" class="pt-20" tabindex="-1">
      <slot />
    </main>

    <FooterNav />

    {shouldLoadAnalytics && <AnalyticsConsent />}

    {loadCodeCopy && (
      <script>
        import "../scripts/code-copy.ts";
      </script>
    )}

    <script>
      import "../scripts/homepage.ts";
    </script>

    <CalEmbed />

    <div
      id="cal-mobile-bar"
      class="fixed bottom-0 left-0 right-0 z-50 md:hidden pb-[env(safe-area-inset-bottom,0px)]"
      style="transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); transform: translateY(0px);"
    >
      <button
        data-cal-link="avaabrazzaq"
        data-cal-namespace="discovery-call"
        data-cal-config='{"layout":"mobile"}'
        class="w-full flex items-center justify-center gap-2 bg-[linear-gradient(120deg,#db7a38,#b05422)] text-[var(--accent-contrast)] font-bold uppercase tracking-[0.05em] text-[0.84rem] px-6 min-h-[56px] active:opacity-90 transition-opacity cursor-pointer shadow-[0_-4px_20px_rgba(176,84,34,0.3)]"
        type="button"
        aria-label="Book a discovery call with Avaab Razzaq"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
          <line x1="16" y1="2" x2="16" y2="6" />
          <line x1="8" y1="2" x2="8" y2="6" />
          <line x1="3" y1="10" x2="21" y2="10" />
        </svg>
        Book a Discovery Call
      </button>
    </div>

    <div class="fixed bottom-6 right-6 z-50 hidden md:block">
      <button
        data-cal-link="avaabrazzaq"
        data-cal-namespace="discovery-call"
        data-cal-config='{"layout":"month_view"}'
        class="inline-flex items-center gap-2 bg-[linear-gradient(120deg,#db7a38,#b05422)] text-[var(--accent-contrast)] shadow-[0_14px_30px_rgba(176,84,34,0.25)] hover:shadow-[0_12px_26px_rgba(15,23,42,0.2)] hover:-translate-y-[1px] rounded-full px-5 py-3 text-[0.84rem] font-bold uppercase tracking-[0.05em] transition-[transform,box-shadow,background] duration-200 cursor-pointer"
        type="button"
        aria-label="Book a discovery call with Avaab Razzaq"
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
          <line x1="16" y1="2" x2="16" y2="6" />
          <line x1="8" y1="2" x2="8" y2="6" />
          <line x1="3" y1="10" x2="21" y2="10" />
        </svg>
        Book a Call
      </button>
    </div>

    <script is:inline>
      (function () {
        var bar = document.getElementById("cal-mobile-bar");
        if (!bar) return;

        var contact = document.querySelector("#contact, [data-section='contact'], section:last-of-type");
        if (!contact) return;

        bar.style.transition = "transform 0.3s cubic-bezier(0.16,1,0.3,1)";

        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              bar.style.transform = entry.isIntersecting ? "translateY(110%)" : "translateY(0)";
            });
          },
          { threshold: 0.25 }
        );

        io.observe(contact);
      })();
    </script>

    <!-- Explicit SW registration so PWA startup still works with Partytown in the page. -->
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker.register("/sw.js").catch(function (err) {
            console.warn("SW registration failed:", err);
          });
        });
      }
    </script>
  </body>
</html>
