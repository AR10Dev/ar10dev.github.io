---
import { Image } from "astro:assets";
import logo from "@assets/logo.png";
import { ICON_BUTTON_CLASSES } from "@lib/constants";
import Navbar from "@solid-components/Navbar";

export interface Props {
  background: string;
}

const { background } = Astro.props as Props;
const links: string[] = ["services", "work", "contact"];
---

<header class={`fixed inset-x-0 top-0 z-50 w-full ${background}`}>
  <div class="mx-auto flex max-w-screen-lg items-center gap-2 p-4 xl:max-w-screen-xl">
    <h1 class="h-16 w-16 flex-none pl-2">
      <a href="#home" aria-label="Go to home section">
        <Image 
          src={logo}
          alt="Avaab Razzaq - AI Growth Engineer" 
          width={64}
          height={64}
          loading="eager"
          decoding="async"
          format="webp"
        />
      </a>
    </h1>
    <nav class="ml-auto flex flex-1 justify-end" aria-label="Primary">
      <Navbar links={links} client:load />
    </nav>
    <button
      id="theme-toggle"
      type="button"
      class={`ml-2 ${ICON_BUTTON_CLASSES.base} ${ICON_BUTTON_CLASSES.elevated}`}
      aria-pressed="false"
      aria-label="Toggle color theme"
      title="Switch to dark mode"
    >
      <span class="sr-only">Toggle color theme</span>
      <svg
        data-theme-icon="moon"
        viewBox="0 0 24 24"
        width="18"
        height="18"
        aria-hidden="true"
        fill="currentColor"
      >
        <path d="M21 14.41A8.98 8.98 0 0 1 9.59 3 9 9 0 1 0 21 14.41Z" />
      </svg>
      <svg
        data-theme-icon="sun"
        class="hidden"
        viewBox="0 0 24 24"
        width="18"
        height="18"
        aria-hidden="true"
        fill="currentColor"
      >
        <path d="M12 18a6 6 0 1 1 0-12 6 6 0 0 1 0 12Zm0-16a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V3a1 1 0 0 1 1-1Zm0 19a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1Zm10-9a1 1 0 0 1-1 1h-1a1 1 0 1 1 0-2h1a1 1 0 0 1 1 1ZM5 12a1 1 0 0 1-1 1H3a1 1 0 1 1 0-2h1a1 1 0 0 1 1 1Zm13.07 7.07a1 1 0 0 1-1.41 0l-.71-.7a1 1 0 1 1 1.41-1.42l.71.71a1 1 0 0 1 0 1.41ZM8.05 8.05a1 1 0 0 1-1.41 0l-.71-.71a1 1 0 1 1 1.41-1.41l.71.7a1 1 0 0 1 0 1.42Zm10.02-2.12a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0ZM8.05 15.95a1 1 0 0 1 0 1.41l-.71.7a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0Z" />
      </svg>
    </button>
  </div>
</header>
