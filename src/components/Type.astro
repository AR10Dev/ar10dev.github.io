---
import Typer from "@solid-components/Typer";
import type { TyperProps } from "@solid-components/types";

interface Props {
  text: string[];
}

const { text } = Astro.props as Props;

const typer: TyperProps = {
  cursor: true,
  loop: true,
  typingSpeed: 90,
  typingPause: 1300,
  backspaceSpeed: 80,
  text,
};
---

<Typer {...typer} client:load />
