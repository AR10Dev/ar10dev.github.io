<script is:inline>
(function (window, scriptUrl, initCommand) {
  var enqueue = function (api, args) {
    api.q.push(args);
  };
  var documentRef = window.document;

  window.Cal = window.Cal || function () {
    var cal = window.Cal;
    var args = Array.prototype.slice.call(arguments);

    if (!cal.loaded) {
      cal.ns = {};
      cal.q = cal.q || [];
      documentRef.head.appendChild(documentRef.createElement("script")).src = scriptUrl;
      cal.loaded = true;
    }

    if (args[0] === initCommand) {
      var namespaceApi = function () {
        enqueue(namespaceApi, Array.prototype.slice.call(arguments));
      };
      var namespace = args[1];
      namespaceApi.q = namespaceApi.q || [];

      if (typeof namespace === "string") {
        cal.ns[namespace] = cal.ns[namespace] || namespaceApi;
        enqueue(cal.ns[namespace], args);
        enqueue(cal, ["initNamespace", namespace]);
      } else {
        enqueue(cal, args);
      }

      return;
    }

    enqueue(cal, args);
  };
})(window, "https://app.cal.com/embed/embed.js", "init");

(function () {
  var loadCal = function () {
    if (window.__calEmbedLoaded) {
      return;
    }

    var cal = window.Cal;
    if (!cal) {
      return;
    }

    window.__calEmbedLoaded = true;

    var namespace = "discovery-call";
    var layout = window.innerWidth < 768 ? "mobile" : "month_view";

    cal("init", namespace, { origin: "https://cal.com" });

    var namespaceCal = cal.ns[namespace];
    if (!namespaceCal) {
      return;
    }

    namespaceCal("ui", {
      styles: {
        branding: {
          brandColor: "#01696f",
        },
      },
      hideEventTypeDetails: false,
      layout: layout,
    });

    namespaceCal("on", {
      action: "bookingSuccessful",
      callback: function () {
        if (typeof window.gtag !== "undefined") {
          window.gtag("event", "booking_completed", {
            event_category: "conversion",
            event_label: "discovery_call",
            value: 1,
          });
        }
      },
    });
  };

  ["mousedown", "touchstart", "keydown", "scroll"].forEach(function (eventName) {
    document.addEventListener(eventName, loadCal, { once: true, passive: true });
  });
})();
</script>