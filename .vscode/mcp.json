{
  "servers": {
    "astro-docs": {
      "type": "stdio",
      "command": "bunx",
      "args": ["-y", "mcp-remote", "https://mcp.docs.astro.build/mcp"]
    },
    "filesystem": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "-y", 
        "@modelcontextprotocol/server-filesystem", 
        "/workspaces"
      ]
    },
    "typescript-lsp": {
      "type": "stdio",
      "command": "bunx",
      "args": ["-y", "@mizchi/lsmcp"]
    },
    "tailwindcss": {
      "type": "stdio",
      "command": "bunx",
      "args": ["-y", "tailwindcss-mcp-server"]
    },
    "bun-runtime": {
      "type": "stdio",
      "command": "bunx",
      "args": ["-y", "mcp-bun@latest"],
      "env": {
        "DISABLE_NOTIFICATIONS": "true"
      }
    }
  }
}